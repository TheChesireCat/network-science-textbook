\chapter*{Chapter 9}

\section*{Configuration model}

\textbf{Definition 9.1.} The configuration model (CM) is the maximum-entropy model of random graphs with a given degree sequence or degree sequence distribution.

\begin{center}
\begin{tabular}{|c|c|c|}
\hline
Ensemble type & \multicolumn{2}{|c|}{Property/sufficient statistic $f_s$} \\
\cline{2-3}
& Average degree $\bar{k}$ & Degree sequence $\mathbf{k} = \{k_i\}_{i=1}^n$ \\
\hline
Mic & $G(n,m)$, $m = \frac{1}{2}\bar{k}n$ & $\text{CM}(n,\mathbf{k})$ \\
Can & $G(n,p)$, $p = \frac{\bar{k}}{n-1}$ & $\text{SCM}(n,\mathbf{k})$ \\
Hyp & $G(n,\rho)$, $\mathbf{k} \sim \rho$ & $\text{HSCM}(n,\rho)$, $\mathbf{k} \sim \rho$ \\
\hline
\end{tabular}
\end{center}

\section*{9.1 Configuration model $\text{CM}(n,\mathbf{k})$}

\subsection*{9.1.1 Definition}

\textbf{Definition 9.2.} The $\text{CM}(n,\mathbf{k})$ is
\begin{equation}
P_{\text{CM}}(G|n,\mathbf{k}) = \frac{\mathbb{1}\{G \in \mathcal{G}(n,\mathbf{k})\}}{N(n,\mathbf{k})},
\tag{9.1}
\end{equation}
where $\mathcal{G}(n,\mathbf{k})$ is the set of graphs whose degree sequences is $\mathbf{k}$, $N(n,\mathbf{k}) = |\mathcal{G}(n,\mathbf{k})|$, and $\mathbf{k}$ is graphical.

\textbf{Definition 9.3.} A degree sequence $\mathbf{k}$ is \textit{graphical} if $N(n,\mathbf{k}) > 0$.

\textbf{Theorem 9.4 (Erdős-Gallai theorem).} \textit{A degree sequence $\mathbf{k}$ is graphical iff:}

\textit{1.} $\sum_{i=1}^n k_i$ \textit{is even, and}

\textit{2.} $\sum_{i=1}^j k_i \leq j(j-1) + \sum_{i=j+1}^n \min(k_i, j)$ \textit{for all} $j = 1, 2, ..., n$, \textit{where} $k_1 \geq k_2 \geq ... \geq k_n$.

