% ===== Page 3 =====
\subsection{Comments}

\begin{itemize}
\item Hooray, we finally have a property, which is well-defined for any given (real) network!

\item Yes, but NO!

\item If $G$ is from sequence/model $G_n$ whose $P(k)$ in the limit have infinite second moment (e.g., configuration model or preferential attachment with $\gamma < 3$), then $\rho_G$ is NOT defined in the limit. (In general, if $\delta(X) = \delta(Y) = \infty$, then $\rho(X,Y) = 0$ if $\delta(X,Y) < \infty$, and $\rho(X,Y)$ is undefined if $\delta(X,Y) = \infty$.)

\item One reason is the \underline{structural correlations}:
\begin{itemize}
\item Suppose we want uncorrelated network (e.g., the configuration model):
\[
m(k,k') = \frac{m(k)m(k')}{2m} \Leftrightarrow P(k,k') = \frac{kP(k)}{k} \cdot \frac{k'P(k')}{k} \text{ with } P(k) \sim k^{-\gamma}, \gamma < 3;
\]

\item $k_c = \langle k_{max} \rangle \sim n^{\frac{1}{\gamma-1}}$ is the natural cutoff (the expected value of the largest degree);

\item $m(k,k')$ cannot be larger than $n(k)n(k')$:
\[
m(k,k') = \frac{m(k)m(k')}{2m} = \frac{kn(k)k'n(k')}{2m} \leq n(k)n(k') \Longrightarrow
\]
\[
kk' \leq 2m = kn \Longrightarrow
\]

\item $k_s = \sqrt{kn} \sim \sqrt{n}$ is the structural cutoff;

\item If $\gamma < 3$, then $k_s \ll k_c$, so the network cannot be uncorrelated: disassortative correlations are forced by structural constraints: no place for the required number of edges between nodes with degrees $kk' > kn$, so such edges must move elsewhere.
\end{itemize}

\item Yet worse---and in contrast with the argument above(!)---there is a theorem that if $\rho_{G_n}$ does converge, then $\rho_{G_\infty} \geq 0$ (Section 1.5 of Volume I of the textbook), implying that disassortative networks are strictly speaking impossible in the limit.
\end{itemize}

\textbf{In summary:}

\begin{itemize}
\item The (dis)assortativity definitions make sense for any given (real) network,

\item But have major problems in the $n \to \infty$ limit.

\item People just plot $k_{nn}(k)$ and enjoy the plots\ldots:)
\end{itemize}

