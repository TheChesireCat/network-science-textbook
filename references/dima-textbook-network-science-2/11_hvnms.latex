% ===== Page 1 =====
\section*{Chapter 11}

\section*{Hidden variable network models (HVNMs)}

\subsection*{11.1 Definition}

\textbf{Notes:}
\begin{itemize}
\item Hidden variables $\mathbf{x} = \{x_i\}$ may abstract node attributes (metadata) in real networks.
\item HVNMs are very general!
\item \textbf{The rest of the models covered in the rest of the class are all HVNMs!}
\end{itemize}

\textbf{Definition 11.1.} The HVNM$(n, p, \rho)$ is the random graph $G = \{G_{ij}\}_{i<j=1}^n$ generated in two steps:

1. $x_i \stackrel{\text{iid}}{\sim} \rho$, for $i = 1, 2, ..., n$, and then

2. $G_{ij} \stackrel{\text{ind}}{\sim} \text{Bernoulli}[p_{ij}]$ for all pairs $i < j$, where $p_{ij} = p(x_i, x_j)$ is the \textit{connection probability}.

\textbf{Notes:}
\begin{itemize}
\item Both $p$ and/or $\rho$ may (and usually do) depend on $n$.
\item If they don't, the graphs are dense as we will see later.
\item If $\rho(x)$ is ``nice,'' it can be mapped to $U(0,1)$:
\begin{itemize}
\item Let: $F(x) = \int_{-\infty}^x \rho(x')dx'$ be the CDF of $X$.
\item Theorem: If $X \sim \rho(x)$, then $u = F(x) \sim U(0,1)$.
\item Therefore, $x = F^{-1}(u) \sim \rho$ if $u \sim U(0,1)$ (inverse CDF sampling).
\end{itemize}
\item Therefore, HVNM$(n, p_\rho, \rho) = \text{HVNM}(n, p_u, U(0,1))$, where $p_u(u, u') = p_\rho(F^{-1}(u), F^{-1}(u'))$.
\item The space of HVNMs is thus extremely vast, parametrized by connection probability functions $p : [0,1]^2 \mapsto [0,1]$.
\end{itemize}

\subsection*{11.2 Examples}

\begin{itemize}
\item The simplest HVNM example: $\mathcal{G}(n, p)$:
\begin{itemize}
\item $\rho = $ any distribution (e.g., $U(0,1)$);
\item $p(x, x') = p$.
\end{itemize}
\item The simplest non-trivial HVNM example: HSCM$(n, \rho)$
\begin{itemize}
\item $\rho = \rho(k)$;
\item $p(k, k') = 1/\left(\frac{kk'}{\bar{k}^2} + 1\right)$, where $\bar{k} = \int k\rho(k)\, dk$.
\item Note that $p$ depends on $n$.
\end{itemize}
\end{itemize}

