% ===== Page 2 =====
\section*{6.2 Elements of the extreme value theory}

\textbf{Definition 6.7.} The extreme value $k_{\max}$ is the maximum value in a set of $n$ independent samples $k_i$ from a distribution $P(k)$: $k_{\max} = \max_i \{k_i\}$, where $k_i \sim P(k)$, $i = 1, 2, \ldots, n$.

\textbf{Observe:}

\begin{itemize}
\item $k_{\max}$ is a random variable.

\item For any $P(k)$, there exist $n$-dependent constants $c > 0$ and $d \in \mathbb{R}$, such that the $n \to \infty$ limit of $x = (k_{\max} - d)/c$ converges to a distribution $\mathcal{P}(x)$.
\end{itemize}

\textbf{Definition 6.8.} The distribution $\mathcal{P}(x)$ is called the \textit{extreme value distribution} (EVD).

\textbf{Fact:} whatever the original distribution $P(k)$ is, its $\mathcal{P}(x)$ can only be either

\begin{itemize}
\item degenerate (delta function), or

\item generalized EVD (GEVD).
\end{itemize}

\textbf{Definition 6.9.} The CDF of a GEVD is:
\begin{equation}
\mathcal{F}(x) = e^{-\lambda(x)}, \text{ where}
\tag{6.2}
\end{equation}
\begin{equation}
\lambda(x) = \begin{cases}
(1 + \xi \nu(x))^{-1/\xi} & \text{if } \xi \neq 0, \\
e^{-\nu(x)} & \text{otherwise,}
\end{cases} \text{ where,}
\tag{6.3}
\end{equation}
\begin{equation}
\nu(x) = \frac{x - l}{s},
\tag{6.4}
\end{equation}

where

\begin{itemize}
\item $l \in \mathbb{R}$ is the location parameter,

\item $s > 0$ is the scale parameter, and

\item $\xi \in \mathbb{R}$ is the \textit{extreme value index}.
\end{itemize}

The values of parameters $l, s, \xi$ depend on the specific form of distribution $P(k)$.

\textbf{Definition 6.10.} The GEVD is also called:

\begin{center}
\begin{tabular}{|l|l|}
\hline
The Weibull distribution & if $\xi < 0$ \\
The Gumbel distribution & if $\xi = 0$ \\
The Fréchet distribution & if $\xi > 0$. \\
\hline
\end{tabular}
\end{center}

Therefore, \textit{any} ``good-looking'' distribution $P(k)$ (whose EVD is not degenerate) belongs to one of the following three classes of the distributions, known as the \textit{maximum domains of attraction} (MDA) of an EVD:

\begin{center}
\begin{tabular}{|c|c|l|}
\hline
$\xi$ & MDA & Description of $\{P(k)\}$s \\
\hline
$\xi < 0$ & Weibull & Distributions with bounded support \\
$\xi = 0$ & Gumbel & All other distributions \\
$\xi > 0$ & Fréchet & Regularly varying distributions \\
\hline
\end{tabular}
\end{center}

Observe that the Fréchet MDA is exactly the space of \textit{all} power-law distributions!

\textbf{Facts:}

\begin{itemize}
\item If $P(k)$ is a power-law distribution (i.e., if $P(k)$ belongs to the Fréchet MDA whose $\xi > 0$), then

\quad $-$ its CCDF (and PDF) exponents $\alpha$ (and $\gamma$) are related to its extreme value index $\xi$ via

\begin{equation}
\boxed{\xi = \frac{1}{\alpha} = \frac{1}{\gamma - 1}}.
\tag{6.5}
\end{equation}
\end{itemize}

\vspace{1em}
\begin{center}
20
\end{center}

\newpage

% ===== Page 3 =====
\begin{itemize}
    \item $l = 1$, $s = \xi$, $d = 0$, $c = F^{-1}(1 - 1/n)$ where $F^{-1}$ is the inverse CDF of $P(k)$, so
    \begin{equation}
    \mathcal{P}(x) = e^{-x^{-1/\xi}}, \text{ where } x \geq 0, \tag{6.6}
    \end{equation}
    \begin{equation}
    \bar{x} = \int_0^\infty x \mathcal{P}(x) \, dx = \Gamma(1 - \xi) \text{ if } \xi < 1 \, (\gamma > 2). \tag{6.7}
    \end{equation}
\end{itemize}

\begin{itemize}
    \item If $P(k)$ is Pareto, i.e., the pure power law
    \begin{equation}
    P(k) = (\gamma - 1)k_{\min}^{\gamma-1}k^{-\gamma}, \text{ where } k \geq k_{\min} > 0, \text{ and } \gamma > 2, \tag{6.8}
    \end{equation}
    then
    \begin{equation}
    c = k_{\min}n^{\xi}, \tag{6.9}
    \end{equation}
    \begin{equation}
    k_{\max} \approx \bar{x}c = \Gamma(1 - \xi)k_{\min}n^{\xi}. \tag{6.10}
    \end{equation}
\end{itemize}

\subsection*{6.3 \quad Estimating $\gamma$}

\textbf{How it works:}
\begin{equation}
\mathbf{k} = \begin{bmatrix} k_1 \\ k_2 \\ \vdots \\ k_n \end{bmatrix} \Rightarrow \boxed{\begin{array}{c} \text{Estimator} \\ X \end{array}} \Rightarrow \hat{\xi} \quad \left( = \frac{1}{\hat{\alpha}} = \frac{1}{\hat{\gamma} - 1} \text{ if } \xi > 0 \right), \text{ where} \tag{6.11}
\end{equation}

\begin{itemize}
    \item $\mathbf{k}$ is the degree sequence in a (random) graph,
    \item $X$ is an algorithm, a function, which can be deterministic or non-deterministic,
    \item $\hat{\xi}$ is its output, $X$'s estimate of $\xi$ in $\mathbf{k}$.
\end{itemize}

Observe that if $\mathbf{k}$ is random (e.g., if it comes from a random graph), then $\hat{\xi}$ is also random, even if $X$ is deterministic.

\textbf{Definition 6.11.} An estimator $X$ is \textit{consistent} (= ``good'') if $\hat{\xi} \to \xi$ as $n \to \infty$ under certain assumptions.

\textbf{Comments:}

\begin{itemize}
    \item The most common assumption of many (most) good $X$'s is that $\{k_i\}_{i=1}^n$ are $n$ independent samples from a given distribution $P(k)$.
    
    \item Many good $X$'s are actually $X(\mathbf{k}, \kappa)$ where $\kappa$ is the number of largest $k_i$'s in $\mathbf{k}$ that $X$ actually works with (it ignores all other $k_i$'s); as a requirement for consistency, $\kappa \to \infty$, but $\kappa/n \to 0$.
    
    \item The convergence/consistency proofs usually hold for any such $\kappa$.
    
    \item But what $\kappa$ is optimal in terms of error minimization?
    
    \item For very few $X$'s, there exists an auxiliary algorithm $Y$ which computes $\kappa^* = Y(\mathbf{k})$ such that $X(\mathbf{k}, \kappa^*)$ is proven to be:
    \begin{itemize}
        \item consistent, i.e., $\kappa^* \to \infty$ and $\kappa^*/n \to 0$,
        \item optimal, i.e., the estimation error is minimized $\Rightarrow$ the speed of convergence is maximized.
    \end{itemize}
    
    \item The set of such $X$'s is:
    \begin{itemize}
        \item Hill estimator ($\approx$ MLE),
        \item Moments estimator,
        \item Kernel estimator,
    \end{itemize}
    where $Y$ is the double bootstrap method.
    
    \item This $Y$ is not deterministic, making $X(\mathbf{k}, Y(\mathbf{k}))$ non-deterministic even for non-random $\mathbf{k}$!
\end{itemize}

\vspace{1em}
\hfill 21

