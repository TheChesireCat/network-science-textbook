% ===== Page 2 =====
\section*{2.2 Notations}

The \emph{average} or \emph{typical distance} $\bar{d}_n$ is the mean of the distance $d \in (0, \infty)$ between two random nodes at finite positive distance in a (random) network model $G_n$ with $n \to \infty$:
\begin{equation}
\bar{d}_n = \sum_{d=1}^{n-1} d P_n(d) = \sum_{G \in G_n} \bar{d}(G) P_n(G),
\tag{2.1}
\end{equation}
where

\begin{itemize}
\item $P_n(d)$ is the distance distribution in the model, i.e., the probability that two random nodes at finite positive distance in a random graph of size $n$ in the model are at distance $d$,

\item 
\begin{equation}
\bar{d}(G) = \frac{\sum_{i,j=1}^{n} d_{ij}(G) \mathbb{1}\left\{d_{ij}(G) \in (0, \infty)\right\}}{\sum_{i,j=1}^{n} \mathbb{1}\left\{d_{ij}(G) \in (0, \infty)\right\}}
\tag{2.2}
\end{equation}
is the average distance in graph $G$ measured over node pairs at finite positive distance,

\item $d_{ij}(G)$ is the distance (the length of a shortest path) between nodes $i$ and $j$ in graph $G$ ($d_{ii}(G) = 0$ and $d_{ij}(G) = \infty$ if there is no path from $i$ to $j$),

\item
\begin{equation}
\mathbb{1}\left\{X\right\} = \begin{cases}
1, & \text{if } X \text{ is true,} \\
0, & \text{if } X \text{ is false.}
\end{cases}
\tag{2.3}
\end{equation}
is the indicator function, and

\item $P_n(G)$ is the probability of graph $G$ in the model.
\end{itemize}

\section*{2.3 Definitions}

\textbf{Definition 2.1.} We call $G_n$:

\begin{itemize}
\item a \emph{small world} if $\bar{d}_n \ll n^{\varepsilon}$ for $\forall \, \varepsilon > 0$,

\item a small world and also an \emph{ultrasmall world} if $\bar{d}_n \ll \log^{\varepsilon}(n)$ for $\forall \varepsilon > 0$,

\item a \emph{large world} if it is not a small world.
\end{itemize}

\begin{figure}[h]
\centering
\textit{[Figure: A Venn diagram-style illustration showing the classification of network worlds. The diagram consists of a large outer region (shaded light gray) divided by a curved vertical line. The left region is labeled ``LARGE WORLDS'' with the condition $\bar{d}_n \sim n^{\varepsilon}$ displayed below it. The right region is labeled ``SMALL WORLDS'' with the condition $\bar{d}_n \ll n^{\varepsilon}$ displayed below it. Within the small worlds region, there is a smaller nested region (shaded darker gray) labeled ``ultrasmall worlds'' with the condition $\bar{d}_n \ll \log^{\varepsilon} n$ displayed below it. The diagram visually represents the hierarchical relationship between large worlds, small worlds, and ultrasmall worlds based on the asymptotic growth of average distance.]}
\end{figure}

