% ===== Page 3 =====
\section*{8.2 The maximum entropy principle}

\textbf{Key points:}

\begin{itemize}
    \item Entropy is a measure of randomness.
    \item ``Maximally random'' = maximum entropy.
\end{itemize}

\noindent\textbf{Definition 8.1.} An \emph{unbiased network model} $P^*(G)$ w.r.t. a collection of network properties $\{f_s\}_{s=1}^S$ is a model that:

\begin{enumerate}
    \item reproduces these properties, and
    \item is maximally random in all other respects:
    \begin{equation*}
    \boxed{
    \begin{aligned}
    &P^*(G) = \arg\max_{P} S[P] \text{ ``}\{f_s\}\text{-constraints''}\},\\
    &\text{where } S[P] = -\sum_{G} P(G) \log P(G), \text{ and}\\
    &\text{``}\{f_s\}\text{-constraints'' are made precise below.}
    \end{aligned}
    }
    \end{equation*}
\end{enumerate}

\noindent\textbf{Meta-Theorem:} $P^*(G)$ ``encodes'' all the information about $\{f_s\}$, and does NOT ``encode'' any other (junk) information.

\textbf{Key comments:}

\begin{itemize}
    \item $P^*(G)$ does not try to be a \emph{correct model} of any graph $G_0$!
    \item $P^*(G)$ is the \emph{correct null model} of $G_0$, given all the information about $G_0$ contained in $\{f_s\}$!
\end{itemize}

\noindent\textbf{Specifying $\{f_s\}$-constraints}: let $s = 1, 2, \ldots, S$, and

\begin{itemize}
    \item $f_s : \mathcal{G} \to \mathbb{R}^D$ be a collection of $S$ properties (e.g., of $G_0$),
    \item $f_s^* \in \mathbb{R}^D$ be their \emph{fixed} values (e.g., in $G_0$),
    \item $\rho$ be a joint distribution of \emph{random} $f_s^*$ (e.g., in random $G_0$).
\end{itemize}

The ``$\{f_s\}$-constraints'' can be:

\begin{itemize}
    \item sharp, microcanonical:
    \begin{equation}
    f_s(G) = f_s^*,
    \tag{8.1}
    \end{equation}
    
    \item soft, canonical:
    \begin{equation}
    \bar{f}_s \equiv \sum_{G} P(G) f_s(G) = f_s^*,
    \tag{8.2}
    \end{equation}
    
    \item hypersoft, hypercanonical:
    \begin{equation}
    P(\{f_s^*\}) = \rho.
    \tag{8.3}
    \end{equation}
\end{itemize}

\vspace{2em}

\begin{center}
