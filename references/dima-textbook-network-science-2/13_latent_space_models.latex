% ===== Page 8 =====
\section*{13.3 Degree-corrected SRGGs (DC-SRGGs)}

\textbf{A.k.a.:} Geometric Inhomogeneous Random Graphs (GIRGs), or Random Hyperbolic Graphs (RHGs) (GIRGs, because (H)SCM is a.k.a. Inhomogeneous Random Graphs (IRGs)).

\textbf{General idea:}

\begin{itemize}
\item SRGGs are homogeneous (having Poisson degree distributions, if ultrasparse).

\item DC-SRGGs is the maximum-entropy way of making SRGGs inhomogeneous (having any desired degree distribution).
\end{itemize}

\subsection*{13.3.1 Definition}

\textbf{Recall:}

\begin{center}
\begin{tabular}{|c|c|c|}
\hline
Model & $p_{ij}$ & $P(G|\{h,v.\})$ \\
\hline
ER & $1/(e^\lambda + 1)$ & $\sim \exp(-\lambda m(G))$ \\
\hline
SCM & $1/(e^{\lambda_i + \lambda_j} + 1)$ & $\sim \exp(-\sum \lambda_i d_i(G))$ \\
\hline
SRGG & $1/(e^{\beta \mathcal{E}_{ij} + \lambda} + 1)$ & $\sim \exp(-\beta \mathcal{E}(G) - \lambda m(G))$ \\
$(ER + \text{geometry})$ & & \\
\hline
\end{tabular}
\end{center}

where $m(G) = \sum_{i<j} G_{ij}$, $d_i(G) = \sum_j G_{ij}$, $\mathcal{E}(G) = \sum_{i<j} \mathcal{E}_{ij} G_{ij}$, $\mathcal{E}_{ij} = \log |x_i - x_j|$.

\textbf{Question:} what is the maximum-entropy way to combine HSCM and geometry?

\textbf{Definition 13.9.} The canonical DC-SRGG model is defined as follows:

\begin{center}
\begin{tabular}{|c|c|c|}
\hline
Model & $p_{ij}$ & $P(G|\{h,v.\})$ \\
\hline
DC-SRGG & $1/(e^{\beta \mathcal{E}_{ij} + \lambda_i + \lambda_j} + 1)$ & $\sim \exp(-\beta \mathcal{E}(G) - \sum \lambda_i d_i(G))$ \\
$(SCM + \text{geometry})$ & & \\
\hline
\end{tabular}
\end{center}

In hypercanonical DC-SRGGs, $\{x_i\}$ and $\{\lambda_i\}$ are random.

\textbf{Question:} what is the expected degree $\bar{k}(x, \lambda)$ of a node at $(x, \lambda)$? That is, what is the relation between $\lambda_i$ and $\kappa_i$ analogous to the (H)SCM?

\textbf{Theorem 13.10.} \textit{Let $\rho(\kappa)$ be any distribution with a finite mean $\bar{k}$, and}

\begin{itemize}
\item $\kappa_i \sim \rho(\kappa)$,

\item $x_i \sim U(0, n)$,

\item $x_{ij} = n/2 - |n/2 - |x_i - x_j||$, \textit{making $[0, n]$ a circle to get rid of boundary effects,}

\item $n \gg 1$ \textit{to neglect finite size effects,}

\item \textit{and denote}
\begin{align}
\chi_{ij} &= e^{\beta \mathcal{E}_{ij} + \lambda_i + \lambda_j} = x_{ij}^\beta e^{\lambda_i + \lambda_j}, \quad \text{so} \tag{13.16} \\
p_{ij} &= \frac{1}{\chi_{ij} + 1} \approx p_{ij}^{\text{CL}} = \min\left(1, \frac{1}{\chi_{ij}}\right), \tag{13.17}
\end{align}
\end{itemize}

\textit{then the expected degree of node $i$ at $(x_i, \lambda_i)$ in the hypercanonical DC-SRGG model converges to $\kappa_i$,} $\bar{k}(x_i, \lambda_i) \to \kappa_i$, \textit{if}

\begin{center}
\begin{tabular}{|c|c|c|}
\hline
& $\beta > 1$ & $\beta < 1$ \\
\hline
$\lambda_i =$ & $-\beta \log \frac{\kappa_i}{\bar{k}n}$ & $-\log \frac{\kappa_i}{\bar{k}n}$ \\
\hline
$\chi_{ij} =$ & $\left(\frac{ex_{ij}}{\kappa_i \kappa_j}\right)^\beta$ & $\frac{ex_{ij}}{\kappa_i \kappa_j}$ \\
\hline
$c =$ & $\frac{2k \frac{\pi}{\beta} \csc \frac{\pi}{\beta}}{\underset{\beta \to \infty}{\longrightarrow} 2k}$ & $\frac{2^2 k \frac{\pi \beta}{1-\beta}}{\underset{\beta \to 0}{\longrightarrow} \bar{k}n}$ \\
\hline
\end{tabular}
\end{center}

\vspace{1em}
\begin{center}
73
\end{center}

\newpage

% ===== Page 9 =====
\noindent \textbf{Note:} as in the (H)SCM, we can map $\kappa_i \sim \rho$ to $u_i \sim U(0,1)$ via $u_i = F(\kappa_i)$, where $F(x) = \int_{-\infty}^{x} p(x') dx'$ is the CDF of $\rho$, in which case the DC-SRGG graphon (connection probability function) $p(u, x; u', x') : ([0,1] \times [0,n])^2 \mapsto [0,1]$ in Theorem 13.10 becomes
\begin{equation}
p(u, x; u', x') = \frac{1}{|x - x'|^{\beta} e^{\lambda(u) + \lambda(u')} + 1}, \text{ where}
\tag{13.18}
\end{equation}
\begin{equation}
\lambda(u) = \begin{cases}
-\beta \log \frac{F^{-1}(u)}{\sqrt{c}} & \text{if } \beta > 1, \\
-\log \frac{F^{-1}(u)}{\sqrt{c}} & \text{if } \beta < 1.
\end{cases}
\tag{13.19}
\end{equation}

\subsubsection*{13.3.2 \quad Generation, projectivity, exchangeability}

The DC-SRGG model is projective for any $\rho(\kappa)$ and $\beta > 1$:

\noindent \textbf{Projective generation:} set $x_0 = 0$, and for $n = 1, 2, \ldots$
\begin{itemize}
\item $u_n \sim U(0,1)$,
\item $d \sim \text{Exp}[1]$,
\item $x_n = x_{n-1} + d$,
\item connect $n$ to $i = n-1, n-2, \ldots, 1$ with probability $p_{ni} = p(u_n, x_n; u_i, x_i)$ in (13.18):
\end{itemize}

\begin{center}
% \includegraphics[width=0.6\textwidth]{diagram}
\textit{[Image file reference removed; semantic figure meaning is preserved in text description.]}
\end{center}

\noindent \textit{[The page contains a hand-drawn diagram on grid paper showing a projective generation process. The diagram shows points labeled along a horizontal axis at positions 0, $x_i$, $x_n$, and $x_{n+1}$. Vertical dashed lines are drawn at these positions. Points are marked with dots and labels $u_i$, $u_n$, and $u_{n+1}$ appear to indicate uniform random variables. Arrows or connections between points illustrate the connection probabilities described in the algorithm.]}

\noindent \textbf{Exchangeable generation:}
\begin{itemize}
\item sprinkle $n$ points onto $[0,1] \times [0,n]$: for $i = 1, 2, \ldots, n$, $u_i \sim U(0,1)$, $x_i \sim U(0,n)$, and
\item connect all pairs of nodes $i < j$ with probability $p_{ij} = p(u_i, x_i; u_j, x_j)$.
\end{itemize}

\subsubsection*{13.3.3 \quad RHG formulation}

\noindent \textbf{Question:} is there anything special about Pareto $\rho(\kappa)$, especially the one with $\gamma = 3$? Recall, only in this case the HSCM is projective.

\noindent \textbf{Theorem 13.11.} \textit{Let}
\begin{itemize}
\item $\beta > 1$,
\item $x_i \sim U(0,n)$, and make $[0,n]$ a circle,
\item $\theta_i = 2\pi x_i/n \sim U(\mathbb{S}^1)$,
\item $\theta_{ij} = \pi - |\pi - |\theta_i - \theta_j||$ -- the distance between $i$ and $j$ on $\mathbb{S}^1$,
\item $R = 2\log(cn/\pi\kappa_0^2)$,
\item $r_i = R - 2\log(\kappa_i/\kappa_0)$, where $\kappa_i \in [\kappa_0, \infty)$, $\bar{k} = \bar{\kappa} = \kappa_0(\gamma - 1)/(\gamma - 2)$,
\end{itemize}
\textit{then,}
\begin{equation}
\chi_{ij} = \exp\left[\frac{\beta}{2}(d_{ij} - R)\right], \text{ so}
\tag{13.20}
\end{equation}
\begin{equation}
p_{ij} = \frac{1}{e^{\frac{\beta}{2}(d_{ij} - R)} + 1}, \text{ where}
\tag{13.21}
\end{equation}
\begin{equation}
d_{ij} = r_i + r_j + 2\log\frac{\theta_{ij}}{2}
\tag{13.22}
\end{equation}
\textit{is approximately the hyperbolic distance between points $i$ and $j$ on the plane at polar coordinates $(r_i, \theta_i)$ and $(r_j, \theta_j)$.}

\vspace{1em}
\hfill 74

\newpage

% ===== Page 10 =====
\textbf{Notes:}

\begin{itemize}
\item Parameters $\{r_i\}$ (radial coordinates) are similar to $\{\lambda_i\}$: if $\rho(\kappa)$ is Pareto, their distribution is a growing exponential, except not on $(-\infty, R]$, but on $[0, R]$.

\item Hyperbolic space is the space in which space expands exponentially:
\end{itemize}

\begin{figure}[h]
\centering
\textit{[Figure: A circular disk representing the Poincaré disk model of hyperbolic space. The disk has a tan/beige background with a darker boundary circle. Multiple small black dots are distributed throughout the disk, with higher density near the boundary. Several nodes (shown as small circles with red/orange centers) are positioned at various locations within the disk. Dashed black lines connect some of these nodes, forming a network structure. The lines appear to curve slightly due to the hyperbolic geometry. The distribution of points illustrates how hyperbolic space expands exponentially toward the boundary, with points becoming increasingly dense near the edge of the disk.]}
\end{figure}

\textbf{Theorem 13.12.} \textit{If $\rho(\kappa)$ is Pareto$[\gamma = 3]$, then the distribution of radial coordinates is $\rho(r) \sim e^{r-R}$, which is such that the points are distributed uniformly over the hyperbolic disk of radius $R$, according to the hyperbolic metric.}

\textbf{Notes:}

\begin{itemize}
\item If $\beta \to \infty$, then $p_{ij} \to \mathbb{1}\{d_{ij} < R\}$ in (13.21), so the graph generation algorithm can be formulated as follows:
\begin{itemize}
\item sprinkle $n$ points uniformly at random (if $\rho(\kappa) = \text{Pareto}[\gamma = 3]$) over a hyperbolic disk of radius $R$, and
\item connect all pairs of points that are at hyperbolic distances less than $R$ from each other:
\end{itemize}
\end{itemize}

\begin{figure}[h]
\centering
\textit{[Figure: A circular disk representing a hyperbolic network visualization. The disk shows numerous small black dots distributed throughout, with particularly high density near the boundary. Two prominent nodes are marked with black circles and red centers, one near the top center and one in the lower right quadrant. From these nodes, many edges radiate outward. The edges are colored in different shades: green edges appear to connect nodes in one region (particularly dense in the right half), blue/purple edges connect nodes in another region (particularly in the left half), and pink/light colored edges connect across regions. A vertical red line extends upward from the top node. The visualization demonstrates the connectivity pattern in a hyperbolic random graph where nodes within hyperbolic distance $R$ are connected, showing clear community structure with dense local connections and sparser long-range connections.]}
\end{figure}

where $\rho(\kappa) \sim \kappa^{-3}$, $\kappa(r) \sim e^{(R-r)/2}$, $\rho(r) \sim e^{r-R}$, and $R \sim \log n$.

\vspace{1em}
\hfill 75

\newpage

% ===== Page 11 =====
\begin{itemize}
\item Since $p_{ij}$ depends on $n$ (via $R$), this formulation is not projective.

\item Since $p_{ij}$ in (13.21) is Fermi-Dirac, it follows from Theorem 11.2 that
\begin{equation}
P(G|\{r_i,\theta_i\}) = \exp[-\bar{\beta}\mathcal{E}(G) - \lambda m(G)]/Z,
\tag{13.23}
\end{equation}
where $\bar{\beta} = \beta/2$, $\lambda = -\bar{\beta}R$, and
\begin{itemize}
\item $m(G) = \sum_{i<j} G_{ij}$ -- the number of edges in $G$,
\item $\mathcal{E}(G) = \sum_{i<j} d_{ij}G_{ij}$ -- the sum of the hyperbolic lengths of all links in $G$,
\end{itemize}
so the RHG model with frozen coordinates $(r_i,\theta_i)$ is the ERGM with the two sufficient statistics above.

\item This interpretation of the model is purely geometric, not referring to any node degrees.

\item Therefore, hyperbolic geometry is a candidate ``mechanism'' responsible for the emergence of not only clustering ($\Leftarrow$ geometry), but also power laws ($\Leftarrow$ hyperbolicity) in real-world networks.

\item \textbf{The GIRG versus RHG formulations in a nutshell:}
\begin{itemize}
\item GIRG: the canonical model has $n+1$ sufficient statistics:
\begin{itemize}
\item $\langle d_i \rangle = \kappa_i$, where $d_i(G) = \sum_j G_{ij}$, $i=1,\ldots,n$, and
\item $\langle \mathcal{E} \rangle = \bar{\mathcal{E}}$, where $\mathcal{E}(G) = \sum_{i<j} \mathcal{E}_{ij}G_{ij}$, $\mathcal{E}_{ij} = \log x_{ij}$, $x_{ij}$ -- distance in $\mathbb{R}$,
\end{itemize}
over the space of $n$-sized graphs that are double-labeled: by $\{i\}$ and $\{x_i\}$;
\item RHG: the canonical model has 2 sufficient statistics:
\begin{itemize}
\item $\langle m \rangle = \bar{m}$, where $m(G) = \sum_{i<j} G_{ij}$, and
\item $\langle \mathcal{E} \rangle = \bar{\mathcal{E}}$, where $\mathcal{E}(G) = \sum_{i<j} \mathcal{E}_{ij}G_{ij}$, $\mathcal{E}_{ij} = d_{ij}$, $d_{ij}$ -- distance in $\mathbb{H}^2$,
\end{itemize}
over the space of $n$-sized graphs that are triple-labeled: by $\{i\}$, $\{x_i|\theta_i\}$, and $\{\kappa_i|\lambda_i|u_i|r_i\}$.
\end{itemize}
\end{itemize}

\subsubsection{Clustering and small-worldness}

\textbf{Theorem 13.13.} \textit{Similar to the homogeneous SRGGs, the average clustering in RHGs at $n \to \infty$ is $\bar{c} = 0$ if $\beta < 1$, and $\bar{c}(\beta)$ is a monotonically increasing function of $\beta$ at $\beta > 1$.}

\textbf{Theorem 13.14.} \textit{Two limits of RHGs:}

\begin{enumerate}
\item RHG $\xrightarrow{\beta \to 0}$ HSCM for any $\rho(\kappa)$,

\item \textit{If $\rho(\kappa) = \text{Pareto}[\gamma,\kappa](\kappa)$, then} RHG $\xrightarrow{\gamma \to \infty}$ SRGG:
\end{enumerate}

\[
\begin{array}{ccc}
\text{RHG} & \xrightarrow{\gamma \to \infty} & \text{SRGG} \\
\beta \to 0 \downarrow & & \downarrow \beta \to 0 \\
\text{HSCM} & \xrightarrow{\gamma \to \infty} & \text{ER}
\end{array}
\]

\vspace{2em}

\hfill 76

\newpage

% ===== Page 12 =====
\textbf{Mega-Theorem:} If $\rho(\kappa) = \text{Pareto}[\gamma, \bar{\kappa}](\kappa)$, then the RHG at $n \to \infty$ has these properties:

\begin{center}
\begin{tabular}{|c|c|c|}
\hline
Parameters & $2 < \gamma < 3$ & $\gamma > 3, \gamma \to \infty$ \\
\hline
$\beta \to 0$ (HSCM) & $\text{USW}(\checkmark)$, $\text{ZC}(\times)$ & $\text{SW}(\checkmark)$, $\text{ZC}(\times)$ \\
$\beta < 1$ & & \\
\hline
$1 < \beta < 2$ & $\text{USW}(\checkmark)$, $\text{PC}(\checkmark)$ & $\text{SW}(\checkmark)$, $\text{PC}(\checkmark)$ \\
$\beta > 2$ & & \\
\hline
$\beta \to \infty$ (sharp geometry) & $\text{USW}(\checkmark)$, $\text{PC}(\checkmark)$ & $\text{LW}(\times)$, $\text{PC}(\checkmark)$ \\
\hline
\end{tabular}
\end{center}

where

\begin{itemize}
\item (U)SW -- (ultra-)small world,
\item LW -- large world,
\item ZC -- zero clustering,
\item PC -- positive (strong) clustering.
\end{itemize}

