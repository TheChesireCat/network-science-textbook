% ===== Page 1 =====
\section*{Chapter 5}

\section*{Data binning}

\subsection*{5.1 Introduction}

It matters what we are binning:

\begin{enumerate}
    \item Functions $f(x)$ (examples: $c(k)$, $k_{nn}(k)$):
    Data: $(x_j, y_j = f(x_i))$, $j = 1, ..., n$.
    
    \item Distributions $P(x)$ (example: $P(k)$) :
    Data: $x_j \sim P(x)$, $j = 1, ..., n$.
    Assumption: $\{x_j\}_{j=1}^n$ is a collection of i.i.d. samples from $P(x)$.
\end{enumerate}

\textbf{Problem:} Bin this data in bins (of different sizes).

\subsection*{5.2 Notations}

\textbf{Let:}

\begin{itemize}
    \item $\mathcal{B} \in \mathbb{N}$ --- number of bins;
    
    \item $\mathcal{B}_i = [b_i, b_{i+1})$ --- bin number $i$, $i = 1, 2, ..., \mathcal{B} - 1$, where $b_i$ is the left boundary of $\mathcal{B}_i$;
    
    \item $\mathcal{B}_\mathcal{B} = [b_\mathcal{B}, b_{\mathcal{B}+1}]$ --- bin number $\mathcal{B}$:
    
    \begin{center}
    \begin{tikzpicture}
        \draw[very thick] (0,0) -- (8,0);
        \foreach \x/\label in {1/b_1, 3/b_2, 5/b_3, 7/b_N} {
            \fill (\x,0) circle (2pt);
            \node[below] at (\x,-0.1) {$\label$};
        }
        \node[above, color=blue] at (2,0.2) {$\mathcal{B}_1$};
        \node[above, color=blue] at (4,0.2) {$\mathcal{B}_2$};
        \node[above, color=blue] at (6,0.2) {$\mathcal{B}_3$};
    \end{tikzpicture}
    \end{center}
    
    \textit{[Note: The figure shows a horizontal line with marked points at positions $b_1$, $b_2$, $b_3$, and $b_N$, with bins $\mathcal{B}_1$, $\mathcal{B}_2$, and $\mathcal{B}_3$ labeled above the intervals between consecutive boundary points.]}
    
    \item $b_1 = \min_j x_j$, $b_{\mathcal{B}+1} = \max_j x_j$;
    
    \item $L_i = |\mathcal{B}_i| = b_{i+1} - b_i$ --- size of $\mathcal{B}_i$;
    
    \item $j_i = \{j : x_j \in \mathcal{B}_i\}$ --- indices of data points falling in $\mathcal{B}_i$;
    
    \item $S_i = |j_i|$ --- number of such data points;
    
    \item $\mathcal{D} = b_{\mathcal{B}+1} - b_1$ --- range of data;
    
    \item $X_i$ --- binned $x_j$;
    
    \item $Y_i$ --- binned $y_j$ or $P(x_j)$.
\end{itemize}

Note: $(X_i, Y_i)$ is what's plotted.

\vfill

\begin{center}
16
\end{center}

