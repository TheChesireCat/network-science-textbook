\section*{Chapter 13}

\section*{Latent space models (LSMs)}

\textbf{Definition 13.1.} Latent Space Models are HVNMs, in which
\begin{enumerate}
    \item hidden variables $\mathbf{x} = \{x_i\}$ are (random) coordinates of nodes in a geometric space ($\Rightarrow \rho(\mathbf{x})$);
    \item connection probability $p(x_i, x_j) = \hat{p}(d(x_i, x_j))$ is a (decreasing) function of the distance $d(x_i, x_j)$ between nodes $i$ and $j$ in the space.
\end{enumerate}

\textbf{Notes:}
\begin{itemize}
    \item Such distances may abstract similarities between people in social networks.
    \item LSMs have been studied in sociology since the 1920s.
    \item Geometry is the best studied mechanism behind the emergence of clustering in real networks (cf. the WS model).
    \item In math, LSMs are known as soft random geometric graphs.
    \item The simplest example is the standard (sharp) random geometric graphs (RGGs).
\end{itemize}

\subsection*{13.1 \quad Random geometric graphs (RGGs)}

\subsubsection*{13.1.1 \quad Definition}

\textbf{Definition 13.2.} In one-dimensional RGGs,
\begin{itemize}
    \item $\rho(x) = U(0, n)$, $x_i \stackrel{\text{iid}}{\sim} \rho(x)$,
    \item $p(x_i, x_j) = \mathbb{1}\,\{0 < |x_i - x_j| < r\} \Leftrightarrow \hat{p}(d) = \mathbb{1}\,\{0 < d < r\}$, where $r > 0$:
\end{itemize}

\begin{figure}[h]
\centering
\textit{[The figure shows a one-dimensional random geometric graph illustration. On a horizontal axis labeled $x$, there are several points distributed along the interval $[0, n]$. Two points are highlighted with a distance $d$ between them. A connection region of width $2r$ is shown centered at one point. The figure includes labels: $x'$ on the vertical axis, $x$ on the horizontal axis, $\hat{p}(x, x')$ indicating the connection probability function, $b$ showing a vertical extent, $\theta$ marking an angle, $2r$ showing the connection radius, and $v_i$ labeling a specific point. Blue shaded regions indicate the neighborhoods where connections occur.]}
\end{figure}

\textbf{Notes:}
\begin{itemize}
    \item The graphs are homogeneous $\Rightarrow$ the expected value of network properties of all nodes are the same (degree, clustering, etc.).
    \item Point density $\lambda = \frac{\text{number of points}}{\text{length of }[0, n]} = 1$.
    \item The expected degree of most $\to$ all nodes is $\bar{k} = \lambda \cdot 2r = 2r$.
    \item The degree distribution $P(k) \to \text{Poisson}[\bar{k}](k) = e^{-\bar{k}} \frac{(\bar{k})^k}{k!}$.
    \item The expected clustering of most $\to$ all nodes is $0 \neq \bar{c} =?$ (Final!)
\end{itemize}

