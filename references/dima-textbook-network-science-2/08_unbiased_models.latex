\section{Canonical ensemble}

\textbf{Theorem 8.3.} \textit{The distribution that maximizes entropy under the canonical constraints (8.2) is}
\begin{equation}
P^*_{\text{can}}(G) = \tilde{P}^*(\{f_s(G)\}) = \frac{1}{Z} \exp\left(-\sum_{s=1}^{S} \lambda_s f_s(G)\right), \tag{8.5}
\end{equation}
\textit{where}
\begin{equation}
Z = \sum_{G} \exp\left(-\sum_{s} \lambda_s f_s(G)\right) \tag{8.6}
\end{equation}
\textit{is the normalization constant (a.k.a. the partition function), and the parameters $\lambda_s$ (a.k.a. the Lagrange multipliers) are the solution of the system of equations}
\begin{equation}
\bar{f}_s \stackrel{\text{HW}}{=} -\frac{\partial \log Z}{\partial \lambda_s} = f_s^*, \quad s = 1, 2, ..., S. \tag{8.7}
\end{equation}

\textbf{Theorem 8.4.} \textit{If ``things are nice'' (e.g., if free energy $\log Z$ is a convex function), which is often the case, then $P^*_{\text{can}}(G)$ is sharply peaked, thus satisfying the first assumption A.1 from the previous chapter.}

\textbf{Note:} since $P^*_{\text{can}}(G) = \tilde{P}^*(\{f_s(G)\})$, the second assumption A.2 is also satisfied, so the definition of typical graphs 7.6 is applicable to canonical ensembles.

\textbf{Definition 8.5.} Distributions in the form (8.5) are knows as:

\begin{itemize}
\item \textit{Gibbs} (or \textit{Boltzmann}) distributions in statistical physics;

\item \textit{Exponential family distributions} in statistics in general, or as \textit{Exponential Random Graph Models (ERGMs)} in the context of random graph models in statistics;

\item \textit{Gibbs measures} in probability.
\end{itemize}

\textbf{Note:} a Gibbs distribution or an ERGM is the maximum-entropy distribution/model with given expected values $f_s^*$ of sufficient statistics $f_s$.

The rest of this section is a couple of examples.

\subsection{Labeled ER $\mathcal{G}(n, p)$}

\begin{align*}
S &= 1, \\
f(G) &= m(G), \\
f^* &= m \in [0, n'], \quad n' = \binom{n}{2}, \\
P^*_{\text{can}}(G) &= \frac{\exp(-\lambda m(G))}{Z}, \\
Z &= \sum_{G \in \mathcal{G}_n} e^{-\lambda m(G)},
\end{align*}

where $\mathcal{G}_n$ is the set of all labeled graphs of size $n$.

Note: $P^*_{\text{can}}[\lambda = 0](G) = 1/|\mathcal{G}_n|$.

To relate $\lambda$ to a given $m$, we need to solve (8.7), for which we have to calculate $Z$. Let $q = e^{-\lambda}$, then
\begin{equation}
Z = \sum_{G \in \mathcal{G}_n} q^{m(G)} = \sum_{l=0}^{n'} \binom{n'}{l} q^l = (1 + q)^{n'}. \tag{8.8}
\end{equation}

So $\log Z = n' \log(1 + q)$, and (8.7) becomes
\begin{equation}
\bar{m} = -\frac{\partial \log Z}{\partial \lambda} = \frac{n'q}{1 + q} = m. \tag{8.9}
\end{equation}

\vspace{1em}
\centerline{38}

\newpage

% ===== Page 7 =====
Define now $d \equiv m/n'$. Since $m$ is the expected number of edges, $d$ is the expected graph density.
The last equation reads then
\begin{equation}
\boxed{d = \frac{q}{1+q} = \frac{e^{-\lambda}}{1+e^{-\lambda}} = \frac{1}{e^{\lambda}+1}}\,.
\tag{8.10}
\end{equation}

This equation is known as the \emph{Fermi-Dirac distribution function} in statistical physics. Inverting it
for $q$,
\begin{equation}
q = \frac{d}{1-d}\,,
\tag{8.11}
\end{equation}
so $1+q = 1/(1-d)$, and
\begin{equation}
Z = (1+q)^{n'} = \frac{1}{(1-d)^{n'}}\,.
\tag{8.12}
\end{equation}

We know have everything in place to write down the explicit expression for $P_{\text{can}}^*(G)$:
\begin{equation}
P_{\text{can}}^*(G) = \frac{e^{-\lambda m(G)}}{Z} = \frac{q^{m(G)}}{(1+q)^{n'}} = \left(\frac{d}{1-d}\right)^{m(G)} (1-d)^{n'} = d^{m(G)}(1-d)^{n'-m(G)}\,,
\tag{8.13}
\end{equation}
which is the probability of graph $G$ in $\mathcal{G}(n,p)$ with
\begin{equation}
p = d.
\tag{8.14}
\end{equation}

\textbf{Note:}
\begin{itemize}
\item $\mathcal{G}(n,p)$ is the canonical maximum-entropy model of random labeled graphs with a given expected number of edges $m = pn'$.
\end{itemize}

\subsubsection*{8.4.2 \quad Unlabeled ER $\mathcal{U}(n,p)$}

\begin{align*}
S &= 1, \\
f(U) &= m(U), \text{ where } U \text{ is an unlabeled graph,} \\
f^* &= m \in [0, n'], \\
P_{\text{can}}^*(U) &= \frac{\exp(-\lambda m(U))}{Z} \\
Z &= \sum_{U \in \mathcal{U}_n} \exp(-\lambda m(U)),
\end{align*}
where $\mathcal{U}_n$ is the set of all unlabeled graphs of size $n$,
\begin{align*}
\bar{m} &= -\frac{\partial \log Z}{\partial \lambda} = m \equiv dn'. \\
\text{Note: } & P_{\text{can}}[\lambda = 0](U) = 1/|\mathcal{U}_n|.
\end{align*}

Unfortunately, these expressions cannot be simplified as in the labeled case.

For example, let $n = 3$, then:

\begin{center}
\begin{tikzpicture}[baseline=-0.5ex]
\node at (0,0) {$\mathcal{U}_n =$};
\node at (1.5,0) {\begin{tabular}{c} $\bullet$ \\ $\bullet$ \quad $\bullet$ \\ $m=0$ \\ $\mathcal{U}_0$ \end{tabular}};
\node at (3,0) {\begin{tabular}{c} $\bullet$ \\ $\bullet$---$\bullet$ \\ $m=1$ \\ $\mathcal{U}_1$ \end{tabular}};
\node at (4.5,0) {\begin{tabular}{c} $\bullet$ \\ $/$ $\backslash$ \\ $\bullet$ \quad $\bullet$ \\ $m=2$ \\ $\mathcal{U}_2$ \end{tabular}};
\node at (6,0) {\begin{tabular}{c} $\bullet$ \\ $/$ $\backslash$ \\ $\bullet$---$\bullet$ \\ $m=3$ \\ $\mathcal{U}_3$ \end{tabular}};
\end{tikzpicture}
\end{center}

so
\begin{equation}
Z = \exp(-\lambda \cdot 0) + \exp(-\lambda \cdot 1) + \exp(-\lambda \cdot 2) + \exp(-\lambda \cdot 3) \frac{q=e^{-\lambda}}{=} \sum_{i=0}^{3} q^i = \frac{1-q^4}{1-q} = \frac{1-e^{-4\lambda}}{1-e^{-\lambda}}\,,
\tag{8.15}
\end{equation}
\begin{equation}
d = \frac{m}{n'} = \frac{1}{3} \cdot \frac{\partial \log Z}{\partial \lambda} = \frac{1}{3}\left(1 - \tanh \lambda + \frac{1}{1+e^{\lambda}}\right)\;;
\tag{8.16}
\end{equation}

