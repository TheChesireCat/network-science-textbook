% ===== Page 4 =====
\section*{8.3 Microcanonical ensemble}

Note: ``ensemble'' means \emph{model} $(P(G))$.

Observe: $\mathcal{G}(\{f_s^*\}_{s=1}^S) = \{G : f_s(G) = f_s^*, s = 1, 2, ..., S\}$ is a finite set, which can be empty, for any finite $n$.

\textbf{Theorem 8.2:} \emph{The maximum-entropy distribution on a finite set is uniform, so}
\begin{equation}
P_{\text{mc}}^*(G) = \frac{\mathbb{1}\{G \in \mathcal{G}(\{f_s^*\})\}}{|\mathcal{G}(\{f_s^*\})|}.
\tag{8.4}
\end{equation}

The rest of this section is a couple of examples.

\subsection*{8.3.1 Labeled ER $\mathcal{G}(n, m)$}

\begin{align*}
S &= 1, \\
f(G) &= m(G) = \sum_{i<j} G_{ij}, \\
f^* &= m \in \{0, 1, ..., n'\}, \quad n' = \binom{n}{2}, \\
|\mathcal{G}(n, m)| &= \binom{n'}{m} \\
P_{\text{mc}}^*(G) &= \frac{\mathbb{1}\{m(G) = m\}}{\binom{n'}{m}}.
\end{align*}

\textbf{Note:}

\begin{itemize}
\item $\mathcal{G}(n, m)$ is the microcanonical maximum-entropy model of random labeled graphs with a given number of edges $m$,

\item $\mathcal{G}(n, m)$ is the correct solution to X's problem, if they need randomly labeled graphs.
\end{itemize}

\subsection*{8.3.2 Unlabeled ER $\mathcal{U}(n, m)$}

\begin{align*}
S &= 1, \\
f(U) &= m(U), \text{ where } U \text{ is an \emph{unlabeled} graph,} \\
f^* &= m \in \{0, 1, ..., n'\}, \\
|\mathcal{U}(n, m)| &\text{ is given by Eq. 4.1.8 in Harary and Palmer, \emph{Graphical Enumeration}, 1973,} \\
P_{\text{mc}}^*(U) &= \frac{\mathbb{1}\{m(U) = m\}}{|\mathcal{U}(n, m)|}.
\end{align*}

\textbf{Note:}

\begin{itemize}
\item $\mathcal{U}(n, m)$ is the microcanonical maximum-entropy model of random unlabeled graphs with a given number of edges $m$,

\item $\mathcal{U}(n, m)$ is the correct solution to X's problem if they need unlabeled graphs.
\end{itemize}

