\section*{7.6 Typical property}

Let:
\begin{itemize}
    \item $f : \mathcal{G} \to \mathbb{R}^D$ be fixed (one property),
    \item $P(G)$ is such that $f$ concentrates, i.e., $f$ is sharply peaked at $\bar{f}$. \hfill (A.1)
\end{itemize}

\textbf{Example:} $m$ in $\mathcal{G}(n,p)$:

\begin{center}
\begin{tikzpicture}
% Vertical axis
\draw[->] (0,0) -- (0,5) node[above] {$P(m)$};
% Horizontal axis
\draw[->] (0,0) -- (8,0) node[right] {$m/n^2$ -- graph density};
% Bell curve
\draw[thick, cyan] (1,0.5) .. controls (2,1) and (3,3.5) .. (4,4) 
    .. controls (5,3.5) and (6,1) .. (7,0.5);
% Shaded region
\fill[cyan!20] (3.5,0) -- (3.5,3.8) .. controls (4,4) and (4.5,3.8) .. (4.5,3.8) -- (4.5,0) -- cycle;
% Dashed line at peak
\draw[dashed] (4,0) -- (4,4);
% Peak point
\fill[cyan] (4,4) circle (2pt);
% Labels
\node[cyan] at (2,1) {$\bar{m} - \varepsilon$};
\node[cyan] at (6,1) {$\bar{m} + \varepsilon$};
\node[cyan] at (4,-0.3) {$\bar{m} \approx pn^2$};
\node[cyan, align=left] at (5.5,3.5) {most graphs\\have $m \approx \bar{m}$};
\end{tikzpicture}
\end{center}

\begin{equation}
P(m) = \binom{n'}{m} p^m (1-p)^{n'-m} = \text{Bin}[n', p](m), \quad n' = \binom{n}{2}
\tag{7.1}
\end{equation}

\vspace{1em}

\noindent\textbf{Definition 7.5.} (not bad)

\begin{quote}
\fbox{\parbox{\textwidth}{
If A.1 holds, and $G_0$ is $(f,\varepsilon)$-typical according to Definition 7.3, then $G_0$ has an $\varepsilon$-typical value of property $f$.
}}
\end{quote}

\noindent\textbf{Note:} we do not say that $G_0$ is typical (Definition 7.3), because it may have atypical values of some properties other than $f$, but we say that it has a typical value of property $f$.

\noindent\textbf{Examples:}

\begin{itemize}
    \item Any $G_0$ with $m \in [\bar{m} - \varepsilon, \bar{m} + \varepsilon]$, $\bar{m} = pn'$, has an $\varepsilon$-typical number of edges in $\mathcal{G}(n,p)$.
    
    \item Any $G_0$ with $P(k) : \|P(k) - \text{Bin}[n-1, p](k)\| < \varepsilon$ has an $\varepsilon$-typical degree distribution in $\mathcal{G}(n,p)$.
    
    \item Any $G_0$ with $P(k) : \|P(k) - P_{\text{PA}}(k)\| < \varepsilon$, where $P_{\text{PA}}(k)$ is the degree distribution in the limit of the preferential attachment model (PA), has an $\varepsilon$-typical value of the degree distribution in PA.
\end{itemize}

\vfill

\begin{center}
