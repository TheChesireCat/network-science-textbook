% ===== Page 7 =====
\section*{Option 3}

\textbf{Theorem 9.7.} \textit{If $\rho(k) = \prod_i \rho(k_i)$, and $\rho = \text{Pareto}(\bar{k}, \gamma)$, where $\bar{k} > 0$ and $\gamma > 2$, then all of the following graph generators are equivalent, and sample properly a random graph in $\text{HSCM}(n, \rho)$ by connecting nodes $i$ and $j$ independently with probabilities $p_{ij}$ given by:}

\subsection*{$\boldsymbol{\lambda}$-generator:}

\begin{align}
p_\lambda(\lambda_i, \lambda_j) &= \frac{1}{e^{\lambda_i + \lambda_j} + 1}, \quad \text{where} \\
\lambda_i &\stackrel{i.i.d.}{\sim} \rho(\lambda) = \alpha e^{\alpha(\lambda - R)}, \quad \text{where} \\
\lambda &\in (-\infty, R], \\
\alpha &= \gamma - 1, \\
R &= \frac{1}{2} \log(\nu n), \\
\nu &= \frac{1}{\bar{k}} \left(\frac{\gamma - 1}{\gamma - 2}\right)^2.
\end{align}

\subsection*{$\boldsymbol{k}$-generator:}

\begin{align}
p_k(k_i, k_j) &= \frac{1}{\frac{kn}{k_i k_j} + 1}, \quad \text{where} \\
k_i &\stackrel{i.i.d.}{\sim} \rho(k) = \text{Pareto}[\bar{k}, \gamma](k) = \alpha k_{\min}^\alpha k^{-\gamma}, \quad \text{where} \\
k &\in [k_{\min}, \infty), \\
k_{\min} &= \bar{k} \frac{\gamma - 2}{\gamma - 1}.
\end{align}

\subsection*{$\boldsymbol{u}$-generator:}

\begin{align}
p_u(u_i, u_j) &= \frac{1}{\nu n (u_i u_j)^{1/\alpha} + 1}, \quad \text{where} \\
u_i &\stackrel{i.i.d.}{\sim} \rho(u) = U[0, 1](u), \quad \text{where} \\
u &\in [0, 1].
\end{align}

\subsection*{$\boldsymbol{x}$-generator:}

\begin{align}
p_x(x_i, x_j) &= \frac{1}{\nu n 1^{-2/\alpha} (x_i x_j)^{1/\alpha} + 1}, \quad \text{where} \\
x_i &\stackrel{i.i.d.}{\sim} \rho(x) = U[0, n](x), \quad \text{where} \\
x &\in [0, n].
\end{align}

\subsection*{CL-aproximations:}

\begin{align}
p_\lambda^{\text{CL}}(\lambda_i, \lambda_j) &= e^{-\lambda_i} e^{-\lambda_j}, \\
p_k^{\text{CL}}(k_i, k_j) &= \frac{k_i k_j}{kn}, \\
p_u^{\text{CL}}(u_i, u_j) &= \frac{(u_i u_j)^{-1/\alpha}}{\nu n}, \\
p_x^{\text{CL}}(x_i, x_j) &= \frac{(x_i x_j)^{-1/\alpha}}{\nu n 1^{-2/\alpha}}.
\end{align}

\textbf{Note:} $\lim_{n \to \infty} \text{HSCM}\left(n, \text{Pareto}[\bar{k}, \gamma]\right) = \mathcal{G}(n, p)$ with $p = \bar{k}/n$.

