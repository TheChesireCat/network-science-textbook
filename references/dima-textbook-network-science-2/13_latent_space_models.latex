% ===== Page 4 =====
\section{13.2 Soft random geometric graphs (SRGGs)}

\subsection{13.2.1 Definition}

\textbf{Definition 13.6.} SRGGs are RGGs, except $p(x, x')$ is any function $\tilde{p}(d)$ of distance $d$ between points:

\begin{center}
\begin{minipage}{0.5\textwidth}
\textit{[Figure: A heatmap visualization showing a probability function $\tilde{p}(\mathcal{X}, \mathcal{X}')$ over a 2D space. The plot has axes labeled $\mathcal{X}_1$ (vertical) and $\mathcal{X}_2$ (horizontal). The heatmap displays a diagonal band of high probability (red/white) running from upper-left to lower-right, with lower probabilities (blue) in the off-diagonal regions. This represents the probability of connection as a smooth function of distance between points in the latent space.]}
\end{minipage}
\end{center}

\subsection{13.2.2 Sparsity, projectivity, unbiasedness}

\textbf{Notes:}

\begin{itemize}
\item In what follows, $p(d)$ is $\tilde{p}(d)$.

\item SRGGs are still homogeneous in the limit.

\item Let $n \gg 1$ and shift $[0, n]$ to $[-n/2, n/2]$. Then:
\begin{equation}
\bar{k} = \bar{k}(x = 0) \approx 2n \int_0^{n/2} p(d(0, x)) \, \rho(x) dx \xrightarrow{d(0,x) = x, \rho(x) = 1/n} 
\end{equation}
\begin{equation}
2 \int_0^{n/2} p(x) \, dx \to 2 \int_0^\infty p(x) \, dx. \tag{13.1}
\end{equation}

\item Therefore, if we want (and we do) ultrasparsity ($\bar{k} = \text{const}$) and projectivity ($p(x)$ does not depend on $n$), then $p(x)$ must be integrable, so that the last integral is finite.

\item This implies that $p(x) \ll 1/x$ at $x \to \infty$.

\item Let us satisfy this requirement by setting
\begin{equation}
p(x) = cx^{-\beta}, \quad \text{where } \beta > 1, c > 0. \tag{13.2}
\end{equation}

\item This choice is no good at $x \to 0_+$ since $p \to +\infty$, so let
\begin{equation}
p(x) = \min\left(1, \frac{c}{x^\beta}\right). \tag{13.3}
\end{equation}

\item But this choice is the CL-approximation of
\begin{equation}
p(x) = \frac{1}{\frac{x^\beta}{c} + 1} \,; \tag{13.4}
\end{equation}

\begin{center}
\begin{minipage}{0.5\textwidth}
\textit{[Figure: A plot showing two functions overlaid. The vertical axis represents probability $p$ from 0 to 1, and the horizontal axis represents distance $x$. One curve (labeled $\min(1, \frac{1}{x^2})$) shows a sharp transition from 1 to a power-law decay. The other curve (labeled $\frac{1}{x^2+1}$) shows a smooth transition. Both curves converge for large $x$, demonstrating that the min function is a CL-approximation of the smooth rational function.]}
\end{minipage}
\end{center}

\item Denote $\mathcal{E}(x) = \ln x$, $\lambda = -\ln c$, $\mu = -\lambda/\beta$. With these notations, Eq.~(13.4) becomes
\begin{equation}
p(x) = \frac{1}{e^{\beta \mathcal{E}(x) + \lambda} + 1} = \frac{1}{e^{\beta(\mathcal{E}(x) - \mu)} + 1}. \tag{13.5}
\end{equation}

\end{itemize}

\vspace{1em}
\hfill 69

\newpage

% ===== Page 5 =====
\begin{itemize}
\item That is, two nodes $i$ and $j$ at coordinates $x_i$ and $x_j$ and distance $d_{ij} \equiv x_{ij} = |x_i - x_j|$ from each other are connected with probability
\begin{equation}
p_{ij} = \frac{1}{e^{\beta \mathcal{E}_{ij} + \lambda} + 1} = \frac{1}{e^{\beta(x_{ij} - \mu)} + 1}, \text{ where}
\tag{13.6}
\end{equation}
\begin{equation}
\mathcal{E}_{ij} = \mathcal{E}(x_{ij}) = \ln |x_i - x_j|.
\tag{13.7}
\end{equation}

\item Since the probability in Eq.~(13.6) is Fermi-Dirac, we use the general Theorem 11.2 with $\lambda_{ij} = \beta \mathcal{E}_{ij} + \lambda$ to deduce that SRGGs with fixed $\{x_i\}$ are canonical ensembles (ERGMs),
\begin{equation}
P(G|\{x_i\}) = \frac{\exp(-\beta \sum_{i<j} \mathcal{E}_{ij} G_{ij} - \lambda \sum_{i<j} G_{ij})}{Z},
\tag{13.8}
\end{equation}
with the following two sufficient statistics:
\begin{itemize}
\item $m(G) = \sum_{i<j} G_{ij}$ -- the number of edges,
\item $\mathcal{E}(G) = \sum_{i<j} \mathcal{E}_{ij} G_{ij}$ -- the total log-length of all edges.
\end{itemize}

\item The latter is equivalent to $\prod_{i<j} x_{ij} G_{ij}$ -- product of the lengths of all edges.

\item To know $\mathcal{E}(G)$, we must know $\{x_i\}$, so the graphs $G$ are labeled not only by $\{i\}$, but also by $\{x_i\}$.

\item SRGGs with random $\{x_i\}$ are thus hypercanonical ensembles (probabilistic mixtures of ERGMs) with these sufficient statistics.

\item The corresponding microcanonical ensembles are highly degenerate (consist of $\sim 1$ graph) since $\{x_i\} \Rightarrow \{\mathcal{E}_{ij}\}$ are reals.

\item Eq.~(13.6) is the vanilla Fermi-Dirac distribution function in the \emph{grand canonical} ensemble in statistical physics:
\begin{itemize}
\item particles -- edges;
\item $\mathcal{E}_{ij}$ -- energy of particle $(i, j)$;
\item $\beta$ -- inverse temperature, the Lagrange multiplier that fixes the average energy (here, $\beta$ controls the average link length $\bar{\mathcal{E}}$);
\item $\mu$ -- chemical potential, the Lagrange multiplier that fixes the average number of particles (here, $\mu$ controls the average degree $\bar{k}$).
\end{itemize}
\end{itemize}

\subsubsection{Small-worldness}

\textbf{Notes:}

\begin{itemize}
\item Observe that the $\beta \to \infty$ limit of the connection probability in Eq.~(13.6) is
\begin{equation}
p_{ij} \xrightarrow{\beta \to \infty} \mathbb{1}\{\mathcal{E}_{ij} < \mu\} = \mathbb{1}\{x_{ij} < e^{\mu} \equiv r\}:
\tag{13.9}
\end{equation}

\begin{center}
\begin{tabular}{|c|c|c|c|c|c|c|}
\hline
\multicolumn{7}{|c|}{$p(x)$} \\
\hline
\multicolumn{7}{|c|}{$\beta = \infty$ (RGG)} \\
\hline
1 & \multicolumn{6}{c|}{} \\
\hline
\multicolumn{7}{|c|}{$\beta = cp$ (SRGG)} \\
\hline
\multicolumn{7}{|c|}{$r$ \hspace{3cm} $\infty$} \\
\hline
\end{tabular}
\end{center}

\noindent
\textit{[The table above represents a hand-drawn sketch showing $p(x)$ as a function of distance. For $\beta = \infty$ (RGG), the probability is a step function: $p(x) = 1$ for $x < r$ and $p(x) = 0$ for $x > r$. For finite $\beta$ (SRGG), the probability smoothly transitions from 1 to 0 around $r$.]}

\item That is, RGGs are the zero-temperature limits of SRGGs:
\[
\boxed{\text{SRGG} \xrightarrow{\beta \to \infty} \text{RGG}}
\]

\item If $\beta = \infty$ and $r = \text{const.}$, then there are no long links (which shortcut to remote places), so RGGs are large worlds.
\end{itemize}

\vspace{1em}
\begin{center}
70
\end{center}

\newpage

% ===== Page 6 =====
\begin{itemize}
\item But if $\beta < \infty$, then shortcuts are there; the more shortcuts and the longer they are, the smaller the $\beta$.
\item \textbf{Questions:}
\begin{itemize}
\item[$-$] Do SRGGs with $\beta < \infty$ remain large worlds, or do they become small worlds?
\item[$-$] If the latter, are they small worlds for any $\beta < \infty$, or must $\beta$ be sufficiently small for small worldness?
\item[$-$] If the latter, then how small must $\beta$ be?
\end{itemize}
\end{itemize}

\textbf{Theorem 13.7.} \textit{SRGGs are small worlds iff $\beta < 2$.}

\textbf{Notes:}

\begin{itemize}
\item Intuitively, this is because if $\beta$ is too large, then there are too few sufficiently long links, not enough to cross large distances.
\item The phase transition from large worldness to small worldness at $\beta = 2$ is very interesting and complex, understood only recently (Tom Hutchcroft, 2025).
\end{itemize}

\subsubsection{Clustering}

Let us now look at what happens at $\beta < 1$: $\bar{k} \sim \int^{n/2} p(x)\,dx \sim \int^n x^{-\beta}\,dx \sim n^{1-\beta} \to \infty$. Therefore, we have two basic options to extend the model for $\beta < 1$:

\begin{itemize}
\item Option 1: Preserve projectivity, lose ultrasparseness by keeping the connection probability the same:
\begin{equation}
p(x) = \min(1, cx^{-\beta}), \tag{13.10}
\end{equation}
\begin{equation}
\bar{k} \approx 2 \int_0^{n/2} p(x)\,dx \sim n^{1-\beta}. \tag{13.11}
\end{equation}

\item Option 2: Preserve ultrasparseness, lose projectivity by forcing the connection probability to decay with $n$:
\begin{equation}
p(x) \equiv p_n(x) = \min(1, c_n x^{-\beta}), \text{ where } c_n \sim 1/n^{1-\beta} \text{ is such that} \tag{13.12}
\end{equation}
\begin{equation}
\bar{k} \approx 2 \int_0^{n/2} p(x)\,dx = \text{const.} \tag{13.13}
\end{equation}

\item We assume Option 2 with $\bar{k} = \text{const.}$ for the rest of this section.

\item With this option, if $\beta \to 0$ (infinite temperature), then
\begin{equation}
p_n(x) \xrightarrow{\beta \to 0} c_n, \tag{13.14}
\end{equation}
\begin{equation}
c_n \to \frac{\bar{k}}{n}. \tag{13.15}
\end{equation}

\item That is, ER is the infinite-temperature limit of SRGG:

\[\boxed{\text{SRGG} \xrightarrow{\beta \to 0} \text{ER}}\]

\item If $\beta = 0$, then clustering is 0 in the $n \to \infty$ limit (ER, no geometry).

\item \textbf{Questions:}
\begin{itemize}
\item[$-$] Do SRGGs with $\beta > 0$ remain to have zero clustering, or do they acquire nonzero clustering?
\item[$-$] If the latter, do they have nonzero clustering at any $\beta > 0$, or must $\beta$ be sufficiently large for nonzero clustering?
\end{itemize}
\end{itemize}

\vspace{1em}
\hfill 71

\newpage

% ===== Page 7 =====
-- If the latter, then how large must $\beta$ be?

\textbf{Theorem 13.8.} \textit{In ultrasparse SRGGs, $\bar{c} > 0$ at $n \to \infty$ iff $\beta > 1$.}

\textbf{Notes:}

\begin{itemize}
\item Intuitively, this is because if $\beta$ is too small, then all links are too long, thus go anywhere, losing geometricity, loosely defined as a sufficiently strong connection between the triangle inequality in the latent space and triangles in the graph.

\item The phase transition at $\beta = 1$ is well understood recently (Jasper van der Kolk \textit{et al}).

\item The coincidence of the projective and nonzero clustering regimes at $\beta > 1$ is remarkable, but the origin for both is well understood: it is integrability of the connection probability function, so it does not have to depend on $n$ for ultrasparsity.

\item The average clustering $\bar{c}(\beta)$ is a non-decreasing function of $\beta$:

\begin{center}
\begin{tikzpicture}
% Description of the plot: A graph showing the relationship between inverse temperature β (x-axis) and average clustering coefficient c̄ (y-axis). The curve starts at a low value near β=1, remains relatively flat or slightly increasing, then rises more steeply before leveling off at a horizontal asymptote labeled c̄_ℓℓℓ. The x-axis is labeled β with an arrow pointing right, and the y-axis is labeled c̄ with an arrow pointing up. A horizontal dashed line indicates the asymptotic value c̄_ℓℓℓ. The curve shows a non-decreasing monotonic behavior.
\end{tikzpicture}

\textit{[Figure description: The plot shows the average clustering coefficient $\bar{c}$ on the vertical axis versus the inverse temperature parameter $\beta$ on the horizontal axis. The curve begins near $\beta = 1$ at a low clustering value, increases monotonically with $\beta$, and asymptotically approaches a horizontal line labeled $\bar{c}_{\ell\ell\ell}$ as $\beta$ increases. The graph illustrates that clustering is a non-decreasing function of $\beta$.]}
\end{center}

\end{itemize}

\subsubsection*{13.2.5 \quad Ultrasparse SRGG summary}

\begin{center}
\begin{tabular}{|c|c|c|}
\hline
Inverse temperature $\beta$ & Strong clustering, projectivity & Small worldness \\
\hline
$\beta \to 0$ (ER) & $\times$ & $\checkmark$ \\
$\beta < 1$ & $\times$ & $\checkmark$ \\
\hline
$1 < \beta < 2$ & $\checkmark$ & $\checkmark$ \\
\hline
$\beta > 2$ & $\checkmark$ & $\times$ \\
$\beta \to \infty$ (RGG) & $\checkmark$ & $\times$ \\
\hline
\end{tabular}
\end{center}

