\section*{9.2 Soft configuration model $\mathrm{SCM}(n, \mathbf{k})$}

\subsection*{9.2.1 Definition}

\textbf{Definition 9.5.} The $\mathrm{SCM}(n, \mathbf{k})$ is
\begin{equation}
P_{\mathrm{SCM}}(G|n, \mathbf{k}) = \frac{\exp(-\sum_{i=1}^n \lambda_i d_i(G))}{Z}, \tag{9.4}
\end{equation}
where $d_i(G)$ is the degree of node $i$ in graph $G$, $d_i(G) = \sum_{j=1}^n a_{ij}$, where $\{a_{ij}\}$ is the adjacency matrix of $G$, and where $\{\lambda_i\}$ are determined below.

\textbf{Determining $\{\lambda_i\}$:}
\begin{align*}
P_{\mathrm{SCM}}(G|n, \mathbf{k}) &= \frac{\exp(-\sum_{i,j=1}^n \lambda_i a_{ij})}{Z} \\
&\underset{a_{ij}=a_{ji}, a_{ii}=0}{=} \frac{\exp(-\sum_{i<j}^n (\lambda_i + \lambda_j)a_{ij})}{Z} \\
&\underset{\lambda_i+\lambda_j=\lambda_{ij}}{=} \frac{\exp(-\sum_{i<j}^n \lambda_{ij}a_{ij})}{Z} \\
&= \frac{\prod_{i<j} \exp(-\lambda_{ij}a_{ij})}{Z} \\
&\underset{e^{-\lambda_{ij}}=q_{ij}}{=} \frac{\prod_{i<j} q_{ij}^{a_{ij}}}{Z}, \quad \text{where}
\end{align*}
\begin{align*}
Z &= \sum_{G \in \mathcal{G}_n} \prod_{i<j} q_{ij}^{a_{ij}} \\
&= \prod_{i<j} \sum_{a=0}^1 q_{ij}^a \\
&= \prod_{i<j} (1 + q_{ij}), \quad \text{so}
\end{align*}
\[
P_{\mathrm{SCM}}(G|n, \mathbf{k}) = \prod_{i<j} \frac{q_{ij}^{a_{ij}}}{1 + q_{ij}}.
\]

Denote $p_{ij} = \frac{q_{ij}}{1+q_{ij}} \in [0, 1]$, so that $1 - p_{ij} = \frac{1}{1+q_{ij}}$, substituting which in the last equation, we get
\begin{equation}
\boxed{P_{\mathrm{SCM}}(G|n, \mathbf{k}) = \prod_{i<j} p_{ij}^{a_{ij}} (1 - p_{ij})^{1-a_{ij}}.} \tag{9.5}
\end{equation}

\textbf{Note:} the last equation means that edges $a_{ij}$ are independent Bernoullis, albeit with different success rates
\begin{equation}
\boxed{p_{ij} = \frac{q_{ij}}{1 + q_{ij}} = \frac{e^{-\lambda_{ij}}}{1 + e^{-\lambda_{ij}}} = \frac{1}{e^{\lambda_{ij}} + 1} = \frac{1}{e^{\lambda_i+\lambda_j} + 1}.} \tag{9.6}
\end{equation}

That is, as in $\mathcal{G}(n, p)$, we have a Fermi-Dirac equation, but edge energies $\lambda_i + \lambda_j$ are now all different.

Since edges are independent Bernoullis, the expected degree $\langle d_i \rangle$ of node $i$ is $\sum_{j=1}^n p_{ij}$ with $p_{ii} = 0$. Therefore, $\{\lambda_i\}_{i=1}^n$ are the solutions of the following system of $n$ nonlinear equations:
\begin{equation}
\boxed{\sum_{j=1}^n p_{ij} = k_i, \quad i = 1, 2, \ldots, n.} \tag{9.7}
\end{equation}

\textbf{Note:}
\begin{itemize}
\item if $k_i \notin [0, n-1]$, then the system does not have a solution, since $p_{ij} \in [0, 1]$ and $p_{ii} = 0$;
\item graphs with the same degree sequence are equiprobable in the model.
\end{itemize}

\vspace{1em}
