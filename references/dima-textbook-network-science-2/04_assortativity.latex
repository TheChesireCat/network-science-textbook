% ===== Page 2 =====
\textbf{Recall:}

\begin{itemize}
\item the covariance between two random variables $X$ and $Y$ is
\begin{equation}
\sigma(X,Y) = \langle(X - \langle X\rangle)(Y - \langle Y\rangle)\rangle = \langle XY\rangle - \langle X\rangle\langle Y\rangle;
\tag{4.6}
\end{equation}

\item the Pearson correlation coefficient is
\begin{equation}
\rho(X,Y) = \frac{\sigma(X,Y)}{\sigma(X)\sigma(Y)},
\tag{4.7}
\end{equation}
where $\sigma(X) = \sqrt{\sigma(X,X)}$ is the standard deviation of $X$;

\item two random variables $X$ and $Y$ are said to be positively correlated, uncorrelated, or negatively correlated if $\rho \in (0,1]$, $\rho = 0$, or $\rho \in [-1,0)$, respectively.
\end{itemize}

\subsection*{4.2 \quad Definitions}

\textbf{Definition 4.1.} The assortativity coefficient of graph $G$ is the Pearson correlation coefficient of its JDD:
\begin{equation}
\boxed{
\rho_G = \rho(k,k') = \frac{\langle kk'\rangle - \left\langle \tilde{k}\right\rangle^2}{\left\langle k^2\right\rangle - \left\langle \tilde{k}\right\rangle^2} = \frac{\langle k\rangle^2 \langle kk'\rangle - \langle k^2\rangle^2}{\langle k\rangle \langle k^3\rangle - \langle k^2\rangle^2},
}
\tag{4.8}
\end{equation}
where
\begin{equation}
\tilde{P}(k) = \sum_{\tilde{k}} P(\tilde{k},k) = \frac{\tilde{k}}{k} P(\tilde{k}),
\tag{4.9}
\end{equation}
\begin{equation}
\langle k^s\rangle = \sum_{k} k^s P(k), \quad s = 1,2,3,
\tag{4.10}
\end{equation}
\begin{equation}
\langle kk'\rangle = \sum_{k,k'} kk' P(k,k').
\tag{4.11}
\end{equation}

Note that if $k_{nn}(k)$ is an increasing, constant, or decreasing function, then $\rho_G > 0$, $\rho_G = 0$, or $\rho_G < 0$, respectively.

\textbf{Definition 4.2.} Network $G$ is called \textit{assortative, uncorrelated,} or \textit{disassortative} if $\rho_G > 0$, $\rho_G = 0$, or $\rho_G < 0$, respectively.

