% ===== Page 6 =====
\section{7.8 Typical sequence}

\noindent\textbf{Definition:} Shannon entropy of distribution $P(x)$: $S[P] = -\sum_x P(x) \log P(x)$.

\noindent\textbf{Theorem:} Let $x_i \stackrel{\text{iid}}{\sim} P(x)$, $i = 1, 2, ..., n$, and $\mathbf{P}(\{x_i\}_{i=1}^n)$ be the probability of the sequence $x_1, x_2, ..., x_n$. Then,
\[
-\frac{1}{n} \log \mathbf{P}(\{x_i\}) \to S[P]
\]

\noindent\textbf{Definition:} A sequence $x_1, x_2, ..., x_n$ is $\varepsilon$-typical w.r.t. $P(x)$ if $\mathbf{P}(\{x_i\}) \in [e^{-n(S(x)+\varepsilon)}, e^{-n(S(x)-\varepsilon)}]$.

\subsection*{Definition 7.7. (good)}

\begin{center}
\fbox{\parbox{0.9\textwidth}{
A sequence of graphs $G_1, G_2, ..., G_n$ is $\varepsilon$-typical in a model $P(G)$ if it is an $\varepsilon$-typical sequence w.r.t. $P(G)$.
}}
\end{center}

\noindent\textbf{Common confusion:} $G_i \stackrel{\text{iid}}{\sim} P(G)$ vs. $a_{ij} \stackrel{\text{iid}}{\sim}$ Bernoulli[$p$] in $\mathcal{G}(n, p)$.

\noindent\textbf{In HW2:} Show that Definition 7.7 applied to edges in $\mathcal{G}(n, p)$ is equivalent to Definition 7.6 of a typical graph in $\mathcal{G}(n, p)$.

\section{7.9 Summary}

\begin{itemize}
\item No network is typical in PA!
\item Any PA network with any average degree $\bar{k}$ is a typical ER network with $p = \bar{k}/n$.
\item The typical \textit{degree distribution} in ER is binomial, and in PA it is a power law.
\end{itemize}

