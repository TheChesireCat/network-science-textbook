% ===== Page 1 =====
\section*{Chapter 4}

\section*{Assortativity}

\section*{4.1 Notations}

Let $P(k, k')$ be the joint degree distribution (JDD), i.e., the probability that a random edge connects nodes of degrees $k$ and $k'$ in a (random) graph $G$.

Observe that in a given fixed graph $G$,
\begin{equation}
P(k, k') = \frac{m(k, k')}{2m},
\tag{4.1}
\end{equation}
where $m$ is number of edges in $G$,
\begin{equation}
m(k, k') = (1 + \delta_{k,k'})n(k, k'),
\tag{4.2}
\end{equation}
where $n(k, k') = n(k', k)$ is the number of edges between nodes of degrees $k$ and $k'$ in $G$, and $\delta_{k,k'}$ is the Kronecker delta:
\[
\delta_{k,k'} = \mathbb{1}\left\{k = k'\right\}.
\]
Let $m(k) = kn(k)$ be the number of stubs (a.k.a. half-edges or edge ends) attached to nodes of degree $k$ (note that $(k, k)$-edges are counted twice).

Observe that $\sum_{k'} m(k, k') = m(k)$. It follows that
\[
\sum_{k'} P(k, k') = \frac{\sum_{k'} m(k, k')}{2m} = \frac{m(k)}{2m} = \frac{kn(k)}{2m} = \frac{knP(k)}{k} = \frac{\bar{k}P(k)}{k} \Longrightarrow
\]
\begin{equation}
\boxed{P(k) = \frac{\bar{k}}{k} \sum_{k'} P(k, k'),}
\tag{4.3}
\end{equation}
implying that the joint degree distribution defines the degree distribution.

Observe that the probability that a random edge attached to a degree-$k$ node (note the conditioning!) goes to a degree-$k'$ node is
\begin{equation}
P(k'|k) = \frac{m(k, k')}{m(k)} = \frac{2mP(k, k')}{kn(k)} = \frac{2mP(k, k')}{knP(k)} = \frac{\bar{k}P(k, k')}{kP(k)} = \frac{P(k, k')}{\sum_{k''} P(k, k'')} = P(k'|k). \tag{4.4}
\end{equation}

Therefore, the average degree of neighbors of nodes of degree $k$ is
\begin{equation}
\boxed{k_{nn}(k) = \sum_{k'} k' P(k'|k) = \frac{\sum_{k'} k' P(k, k')}{\sum_{k''} P(k, k'')}.}
\tag{4.5}
\end{equation}

