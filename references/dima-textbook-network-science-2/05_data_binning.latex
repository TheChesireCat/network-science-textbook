% ===== Page 2 =====
\section{Determining $X_i$}

\subsection{Linear binning}

\begin{itemize}
    \item $L_i = \mathcal{D}/\mathcal{B} = L, \ i = 1, 2, ..., \mathcal{B}$;
    \item $b_i = b_1 + (i-1)L$.
\end{itemize}

Options for $X_i$:
\begin{itemize}
    \item $X_i = b_i$ (most frequent),
    \item $X_i = (b_i + b_{i+1})/2$ (less frequent),
    \item $X_i = b_{i+1}$ (least frequent).
\end{itemize}

\subsection{Logarithmic binning}

\begin{itemize}
    \item $q_1 = \log b_1$ (assumption: $b_1 > 0$);
    \item $q_{\mathcal{B}+1} = \log b_{\mathcal{B}+1}$;
    \item $\mathcal{D}_q = q_{\mathcal{B}+1} - q_1$;
    \item $L_q = \mathcal{D}_q/\mathcal{B}$;
    \item $q_i = q_1 + (i-1)L_q, \ i = 1, ..., \mathcal{B}$;
    \item $b_i = e^{q_i}$ (note: bin sizes grow exponentially!).
\end{itemize}

Options for $X_i$:
\begin{itemize}
    \item $X_i = b_i$ (most frequent),
    \item $X_i = b_{i+1}$ (least frequent),
    \item $Q_i = \frac{1}{2}(q_i + q_{i+1}), \ X_i = e^{Q_i} = \sqrt{b_i b_{i+1}}$ (good for power-law data).
\end{itemize}

\section{Determining $Y_i$}

\begin{itemize}
    \item \textbf{Functions:}
    \begin{equation}
    Y_i = \sum_j y_j \mathbb{1}\left\{j \in j_i\right\} / S_i,
    \tag{5.1}
    \end{equation}
    
    which is the average value of data $\{y_j\}$ in bin $B_i$.
    
    \item \textbf{Distributions:}
    \begin{equation}
    Y_i = \frac{S_i}{L_i n},
    \tag{5.2}
    \end{equation}
    
    because $\langle S_i \rangle = n\text{Prob}(X \in B_i) \approx nP(X_i)L_i = nY_iL_i$.
    Note that the binned data is properly normalized: $\sum_i Y_i L_i = \frac{1}{n} \sum_i S_i = 1$.
\end{itemize}

\vfill
\begin{center}
17
\end{center}

