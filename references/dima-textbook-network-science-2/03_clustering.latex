% ===== Page 2 =====
\subsection{Notations}

Let:

\begin{itemize}
\item $n(k)$ --- number of nodes of degree $k$ in a simplest network $G$,
\item $k_i$ --- the degree of node $i$ in $G$,
\item $w_i = \binom{k_i}{2}$ --- number of pairs of $i$'s neighbors,
\item $t_i$ --- number of connected pairs among those,
\item $w = \sum_i w_i$ --- total number of \textit{wedges} (paths of length 2) in $G$,
\item $t = \sum_i t_i$ --- $3\times$ total number of triangles in $G$.
\end{itemize}

\subsection{Definitions}

\begin{itemize}
\item \textit{The global clustering (coefficient)} of graph $G$:
\begin{equation}
c = \frac{t}{w}.
\tag{3.1}
\end{equation}

\item \textit{The (local) clustering (coefficient)} of node $i$ in $G$:
\begin{equation}
c_i = \frac{t_i}{w_i}.
\tag{3.2}
\end{equation}

Observe: $c_i$ is undefined if $w_i = 0 \iff k_i = 0$ or $k_i = 1$,

\item \textit{The average clustering of nodes of degree} $k$ or \textit{degree-dependent clustering}:
\begin{equation}
c(k) = \frac{1}{n(k)} \sum_i c_i \mathbb{1}\{k_i = k\},
\tag{3.3}
\end{equation}

Observe: $c(k)$ is undefined if $k = 0$ or $k = 1$,

\item \textit{The average (local) clustering (coefficient)}:
\begin{equation}
\bar{c} = \langle c \rangle = \frac{1}{n_{>1}} \sum_i c_i \mathbb{1}\{k_i > 1\} = \sum_{k>1} c(k) P_{>1}(k),
\tag{3.4}
\end{equation}

where $n_{>1} = n - n(0) - n(1)$, $P_{>1}(k) = n(k)/n_{>1}$, $k > 1$.
\end{itemize}

\textbf{Note:}

\begin{itemize}
\item $c, \bar{c} \in [0,1]$,
\item $c, \bar{c} = 0$ in a triangle-free graph,
\item $c, \bar{c} = 1$ in a complete graph,
\item $c = \text{Prob}(\text{a random wedge is a part of a triangle})$; it puts more `weight' on high-degree nodes,
\item $\bar{c} = \text{Prob}(\text{two random neighbors of a random node are connected})$; it puts more `weight' on low-degree nodes.
\end{itemize}

\textbf{Definition 3.1.} We say that a network model/random graph sequence $G_n$ with $n \to \infty$ has \textit{strong clustering} or \textit{high clustering} or \textit{non-vanishing clustering} if $\liminf_{n\to\infty} \bar{c}_n \neq 0$ (the limit may not exist!)

$\star$) Enforcing $c_i = 0$ for $k_i = 0$ or $k_i = 1$ cannot be rigorously justified.

$\star$) The simplest ``mechanism'' that can ``explain'' clustering is geometry.

