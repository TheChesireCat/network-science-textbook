% ===== Page 2 =====
\textbf{Key Points:}

\begin{itemize}
\item No given (real) network is either sparse or dense; we rely only on intuition here.

\item Sparsity is well defined only for network models with $n \to \infty$.

\item And only for simple, unweighted, un\dots (definition: \emph{simplest}) graphs. Other networks (weighted, multilayer, temporal, etc.) should be casted as the simplest first.

\item Given a network history (e.g., Internet's) we can be ``more sure'', but still not rigorous.

\item Adversarial example: $G_{n,p}$ with $n = 10^{10}$, $p = 10^{-10^{10}}$:
\begin{align*}
P(G \text{ with } m \text{ edges}) &= p^m(1-p)^{\binom{n}{2}-m} \implies \\
P(\text{empty graph}) &= (1-p)^{\binom{n}{2}} \approx 1 - \binom{n}{2}p \approx 1 - \frac{1}{2}10^{20-10^{10}} \approx 1
\end{align*}
But this graph is dense: $\bar{k} = p(n-1) \sim n$ if $p$ is constant.
\end{itemize}

\subsection{Notations}

Let $n$ be the size of the network (number of nodes);

$f_n$, $g_n$ two nonnegative functions of $n$ (example: $k_n$: average degree; $m_n$: number of links);

$a \in [0, \infty]$ a constant (i.e., $0 \leq a \leq \infty$); $c \in (0, \infty)$ a constant (i.e., $0 < c < \infty$):

\textbf{Notations:}

\begin{align*}
f_n \to a &\Leftrightarrow \lim_{n \to \infty} f_n = a \\
f_n \ll g_n &\Leftrightarrow f_n/g_n \to 0 \\
f_n \gg g_n &\Leftrightarrow f_n/g_n \to \infty \\
f_n \sim g_n &\Leftrightarrow f_n/g_n \to c \\
f_n \approx g_n &\Leftrightarrow f_n/g_n \to 1
\end{align*}

\textbf{Observe:} `$\ll$', `$\gg$', `$\approx$' also have informal meanings: $0.01 \ll 1$, $100 \gg 1$, $1.01 \approx 1$.

The meaning used is usually clear from the context. If it is unclear, we will use quotes: $1.01$ ``$\approx$''$1$ vs. $n-1 \approx n$.

\textbf{Examples:} $\frac{n/2-5}{n+100} \approx \frac{1}{2}$; $\log^{100} n \ll n^{0.01}$;

$e^{0.01n} \gg n^{100}$; $5n \log n + 7n \sim n \log n$;

$(n^2 - 2)(3 \log n - 5) + 10(n^2 - 3n) \approx 3n^2 \log n$.

