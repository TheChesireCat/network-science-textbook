% ===== Page 2 =====
\subsection{Maximum likelihood}

\textbf{Definition 7.1.} (bad) \fbox{$G_0$ is typical if $G_0 = \arg\max_{G} P(G)$.}

Def 7.1 is bad because, for instance:

\begin{itemize}
\item Any $G \in \mathcal{G}_{n,m}$ is typical. $(P(G) = \mathbb{1}\{m(G) = m\} / \binom{\binom{n}{2}}{m})$.)
\item The empty graph is typical in $\mathcal{G}_{n,p}$ with any $p < 1/2$.
\end{itemize}

\subsection{Graph distances}

\textbf{Definition 7.2.} (bad)

\begin{quote}
Let:
\begin{enumerate}
\item $d : \mathcal{G}^2 \to \mathbb{R}_+$ be a graph distance,
\item $\bar{d} = \mathbb{E}\{d(G, G_0)\}$, where $G \sim P(G)$.
\end{enumerate}

Then $G_0$ is $(d, \varepsilon)$-typical if $\bar{d} < \varepsilon$.
\end{quote}

Definition 7.2 is bad because, for instance:

\begin{itemize}
\item It depends on $d$.
\item The number of different $d$'s is uncountably infinite.
\item The number of ``bad'' (``adversarial'') $d$'s is uncountably infinite (e.g., $d(G_1, G_2) = \pi \mathbb{1}\{G_1 \neq G_2\}$).
\item Even if $d$ is ``good'':
\begin{itemize}
\item It may not concentrate, e.g., $d(G_1, G_2) > \varepsilon_0, \forall G_1, G_2$.
\item It may be difficult to relate $d(G_1, G_2) < \varepsilon$ to the bounds on the difference of a given network property of $G_1$ and $G_2$.
\item The distributions of $d(G, G_0)$ tend to be way more intractable than $P(G)$, so that $\bar{d}$ may be impossible to obtain even empirically.
\end{itemize}
\end{itemize}

\subsection{Graph properties}

\textbf{Definition 7.3.} (bad)

\begin{quote}
Let:
\begin{enumerate}
\item $f : \mathcal{G} \to \mathbb{R}^D$ be a network property,
\item $\bar{f} = \mathbb{E}\{f(G)\}$, where $G \sim P(G)$,
\item $d_f = \|f(G_0) - \bar{f}\|_{\mathbb{R}^D}$.
\end{enumerate}

Then $G_0$ is $(f, \varepsilon)$-typical if $d_f < \varepsilon$.
\end{quote}

Definition 7.3 is bad because, for instance:

\begin{itemize}
\item It depends on $f$.
\item The number of different $f$'s is uncountably infinite.
\item The number of ``bad'' (``adversarial'') $f$'s is uncountably infinite (e.g., $f_{G_0}(G) = \pi \mathbb{1}\{G = G_0\}$).
\end{itemize}

\vspace{1em}
\hfill 27

\newpage

% ===== Page 3 =====
\begin{itemize}
\item Even if $f$ is ``good'', it may not concentrate at $\bar{f}$, e.g., as in the Strauss model (random graphs with given expected numbers of edges $m$ and triangles $t$), where the distribution of the number of triangles is double-peaked:

\begin{center}
\begin{tikzpicture}
\draw[->] (0,0) -- (6,0) node[right] {$t$};
\draw[->] (0,0) -- (0,3.5) node[above] {$\mathcal{P}(t)$};
\draw[thick, cyan] (0.3,0.1) .. controls (1,0.3) and (1.3,1.2) .. (1.8,1.5) 
    .. controls (2.1,1.7) and (2.3,1.7) .. (2.5,1.5)
    .. controls (2.7,1.2) and (2.8,0.5) .. (3,0.3)
    .. controls (3.2,0.5) and (3.5,1.5) .. (4,2.3)
    .. controls (4.3,2.7) and (4.5,2.7) .. (4.8,2.3)
    .. controls (5.1,1.8) and (5.3,1) .. (5.5,0.1);
\draw[dashed] (1.8,0) node[below] {$t_1$} -- (1.8,1.5);
\draw[dashed] (2.5,0) node[below] {$\bar{t}$} -- (2.5,1.5);
\draw[dashed] (4,0) node[below] {$t_2$} -- (4,2.3);
\end{tikzpicture}
\end{center}

so the probability of a graph with the typical number of triangles $t \approx \bar{t}$ is $P(\bar{t}) \approx 0$, and most graphs have either $t \approx t_1 < \bar{t}$ or $t \approx t_2 > \bar{t}$.

\item What if we are interested not in one property $f$, but in two $f_1, f_2$?
\begin{itemize}
\item[--] What if they are not independent (as $m,t$ in the Strauss model)?
\end{itemize}

\item $f_1, f_2, f_3, ...??$

\item All properties $\{f\}!???$
\end{itemize}

\subsection*{7.5 \quad All graph properties}

\textbf{Definition 7.4.} (worst)

\[
\boxed{G_0 \text{ is } \varepsilon_f\text{-typical in } P(G) \text{ if } d_f < \varepsilon_f \text{ for all } f : \mathcal{G} \to \mathbb{R}^D.}
\]

Definition 7.4 is the worst one because no graph is typical in any model because of the ``worst'' property $f(G) = \infty$.

\textbf{Switching to good things\dots}

