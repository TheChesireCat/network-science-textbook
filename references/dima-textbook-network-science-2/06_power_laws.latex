% ===== Page 1 =====
\section*{Chapter 6}

\section*{Power laws}

\subsection*{6.1 Definitions}

\textbf{Definition 6.1.} A function $l(k)$ is \textit{slowly varying} if
\begin{equation}
\lim_{k\to\infty} \frac{l(tk)}{l(k)} = 1 \tag{6.1}
\end{equation}
for any $(\forall)$ $t > 0$.

\textbf{Examples:}

\begin{itemize}
\item Slowly varying $l(k)$:
\begin{itemize}
\item $l(k) = c > 0$,
\item any $l(k)$ such that $\lim_{k\to\infty} l(k) = c > 0$,
\item $l(k) = \log^{\alpha} k$, $\forall \alpha \in \mathbb{R}$.
\end{itemize}

\item Not slowly varying $l(k)$:
\begin{itemize}
\item $l(k) = k^{\alpha}$, $\forall \alpha \in \mathbb{R}\backslash\{0\}$,
\item $l(k) = \sin k$.
\end{itemize}
\end{itemize}

\textbf{Definition 6.2.} A function $f(k)$ is \textit{regularly varying} if $f(k) = l(k)k^{-\alpha}$, where $\alpha > 0$ and $l(k)$ is a slowly varying function.

\textbf{Theorem 6.3} (Karamata theorem). \textit{If the PDF of a distribution is a regularly varying function, then so its CCDF.}

The converse is not true in general (e.g., $P(x) = (\sin x)^2/x^3$).

\textbf{Definition 6.4.} A probability distribution is \textit{regularly varying} if its CCDF is a regularly varying function.

\textbf{Definition 6.5.} A probability distribution is a \textit{power law} if it is regularly varying.

\textbf{Definition 6.6.} A probability distribution is a \textit{pure} (or ``clean'') power law if its slowly varying function $l(k)$ is constant.

\textbf{Observation:} No empirical $P(k)$, in any given (real) network, is a power law!

\textbf{Comments:}

\begin{itemize}
\item As with sparsity, small worldness, and strong clustering, it is impossible in principle to tell whether the degree distribution in any network is a power law.

\item The difference with sparsity, small worldness, and clustering is that in those cases, the corresponding network properties $\bar{k}$, $d$, $\bar{c}$ are well-defined and easy to compute for any given network; with power laws, we do not have any $\gamma$ to begin with; it needs to be estimated first.

\item All the ``good'' estimators below estimate $\gamma$ not directly, but via the extreme value index $\xi$.
\end{itemize}

\vspace{1em}
