% ===== Page 3 =====
\section{Most famous examples}

\subsection{Erdős-Rényi graphs}

Small worlds, and also ultrasmall worlds if $k = (n-1)p \sim n^\varepsilon, \forall \varepsilon > 0$.
Here is why:
\begin{equation}
\bar{d}_n \sim \frac{\log n}{\log k}
\tag{2.4}
\end{equation}

from the tree-like approximation, so

\begin{itemize}
\item if $\bar{k} \to c > 1$, then $d_n/\log n \to 1/\log \bar{k}$ 
(Theorem 2.36 or Exercise 6.1 in Volume II of the textbook),

\item if $p = \text{const}$, then $\bar{d}_n \sim 1$ (diameter is also bounded).
\end{itemize}

\subsection{Power-law configuration model \& preferential attachment}

Small worlds for any $\gamma$, and also ultrasmall worlds if $\gamma < 3$:

\begin{itemize}
\item if $\gamma > 3$, then $d_n/\log n \to 1/\log \nu$, $\nu = \langle k^2 \rangle/\langle k \rangle$,

\item if $\gamma = 3$, then $d_n/\frac{\log n}{\log \log n} \to 1$,

\item if $\gamma \in (2,3)$, then $d_n/\log \log n \to c/|\log(\gamma - 2)|$, where $c = 2$ (CM) and $c = 4$ (PA),

\item if $\gamma < 2$, then $d_n \to$ either 2 or 3.
\end{itemize}

\section{Comments}

\begin{itemize}
\item The graph diameter in the ER model is
\begin{equation}
\mathcal{D}_n \sim \frac{\log(n)}{\log(np)},
\tag{2.5}
\end{equation}

\begin{itemize}
\item[--] if $np \to \bar{k} > 1$ (thus ultrasparse graphs), then $\mathcal{D}_n/\frac{\log(n)}{\log(np)} \in [1, f(\bar{k})]$ with high probability (w.h.p.), where $f(k) \in [1,\infty)$ (note: $\mathcal{D}_n/\frac{\log(n)}{\log(np)} \sim \mathcal{D}_n/\log(n))$;

\item[--] if $p = \text{const}$, then $\mathcal{D}_n/\frac{\log(n)}{\log(np)}$ is concentrated on at most two values (note: $\mathcal{D}_n/\frac{\log(n)}{\log(np)} \sim \mathcal{D}_n$).
\end{itemize}

\item In our definition, $\bullet - \bullet$ \quad $\bullet - \bullet$ \quad $\bullet - \bullet$ \ldots is an ultrasmall world, but $\text{Prob}(d = \infty) \to 1$.
\end{itemize}

