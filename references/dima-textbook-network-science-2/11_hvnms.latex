\section*{11.3 Frequently used expressions}

\begin{enumerate}
\item The expected number of edges:
\begin{equation}
\bar{m} = \binom{n}{2} \iint p(x,x') \, \rho(x) dx \, \rho(x') dx'. \tag{11.1}
\end{equation}

\item The expected average degree:
\begin{equation}
\bar{k} = (n-1) \iint p(x,x') \, \rho(x) dx \, \rho(x') dx'. \tag{11.2}
\end{equation}

\item The expected degree of a node with hidden variable $x$ (node at $x$):
\begin{equation}
\bar{k}(x) = (n-1) \int p(x,x') \, \rho(x') dx'. \tag{11.3}
\end{equation}

\item The expected number of triangles at a node at $x$:
\begin{equation}
\bar{t}(x) = \binom{n-1}{2} \iint p(x,x') p(x',x'') p(x'',x) \, \rho(x') dx' \, \rho(x'') dx''. \tag{11.4}
\end{equation}

\item The expected number of triangles:
\begin{equation}
\bar{t} = \frac{n}{3} \int \bar{t}(x) \, \rho(x) dx. \tag{11.5}
\end{equation}

\item The expected clustering of a node at $x$:
\begin{equation}
\bar{c}(x) = \iint p(x',x'') \, p(x') x) dx' \, \rho(x'') dx'', \quad \text{where} \tag{11.6}
\end{equation}

\item The distribution of the values of hidden variables $x'$ of nodes connected to a node at $x$:
\begin{equation}
\rho(x'|x) = (n-1) \rho(x') p(x',x) / \bar{k}(x). \tag{11.7}
\end{equation}

\item Combining the equations above:
\begin{equation}
\bar{c}(x) = 2 \frac{n-2}{n-1} \frac{\bar{t}(x)}{[\bar{k}(x)]^2} \approx \frac{2\bar{t}(x)}{[\bar{k}(x)]^2}. \tag{11.8}
\end{equation}

\item The expected average clustering excluding nodes of degrees 0 and 1:
\begin{equation}
\bar{c} = \int \bar{c}(x) \, \rho(x) dx. \tag{11.9}
\end{equation}
\end{enumerate}

\section*{11.4 HVNMs versus ERGMs in general}

\textbf{Theorem 11.2.} \textit{The generalized ER graph $\mathcal{G}(n, \{p_{ij}\})$, where $p_{ij} \in [0,1]$ is the probability of link $\{i,j\}$, is an ERGM with $\binom{n}{2}$ sufficient statistics $f_{ij}(G) = G_{ij}$, $i < j$ (property $f_{ij}$ is the indicator of the presence of edge $\{i,j\}$). Specifically,}
\begin{equation}
P(G) = \prod_{i<j} p_{ij}^{G_{ij}} (1-p_{ij})^{1-G_{ij}} = \frac{1}{Z} \exp(-\sum_{i<j} \lambda_{ij} G_{ij}), \quad \text{where} \tag{11.10}
\end{equation}
\begin{equation}
Z = \prod_{i<j} (1 + e^{-\lambda_{ij}}), \tag{11.11}
\end{equation}
\begin{equation}
p_{ij} = \frac{1}{e^{\lambda_{ij}} + 1}. \tag{11.12}
\end{equation}

Note that this is a ``very dull and degenerate'' ERGM (canonical ensemble), since the corresponding microcanonical ensemble consists of individual graphs:
\begin{equation}
P(G|\{G_{ij}\}) = \mathbb{1}\, \{G = \{G_{ij}\}\}. \tag{11.13}
\end{equation}

Regardless, a general HVNM is a hypercanonical probabilistic mixture of canonical $\mathcal{G}(n, \{p_{ij}\})$ with random $p_{ij} = p(x_i, x_j)$: $\{p_{ij}\}$ are random because $\{x_i\}$ are random.

