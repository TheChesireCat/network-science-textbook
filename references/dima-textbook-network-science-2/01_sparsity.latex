% ===== Page 3 =====
\subsection{Definitions}

\begin{center}
\begin{tabular}{|c|c|c|c|c|}
\hline
\multicolumn{3}{|c|}{Properties} & \multicolumn{2}{c|}{Definitions} \\
\hline
Graph density $d$ & Average degree $\bar{k}$ & Number of links $m$ & Literature & This course \\
\hline
$d_n \sim 1$ & $\bar{k}_n \sim n$ & $m_n \sim n^2$ & Dense & Dense \\
\hline
$d_n \ll 1$ & $\bar{k}_n \ll n$ & $m_n \ll n^2$ & Sparse (math) & \multirow{2}{*}{Sparse} \\
\cline{1-4}
& & & Not dense (phys) & \\
& & & Dense (phys) & \\
\hline
$d_n \sim 1/n$ & $\bar{k}_n \sim 1$ & $m_n \sim n$ & Sparse (phys, math) & Sparse and also \\
$d_n \ll 1/n$ & $\bar{k}_n \ll 1$ & $m_n \ll n$ & Ultrasparse & Ultrasparse \\
& & & Truly sparse & \\
\hline
\end{tabular}
\end{center}

\vspace{1em}

\begin{figure}[h]
\centering
\textit{[The figure shows a Venn diagram-style illustration with two overlapping regions. The left region is labeled ``DENSE GRAPHS'' with the condition $\bar{k}_n \sim n$ written inside. The right region is labeled ``SPARSE GRAPHS'' with the condition $\bar{k}_n \ll n$ written inside. Within the sparse graphs region, there is a smaller nested region labeled ``ultrasparse graphs'' with the condition $\bar{k}_n \to c < \infty$ written inside. The regions are drawn with curved boundaries and shaded in gray, with the ultrasparse region appearing as a subset nested within the sparse graphs region.]}
\end{figure}

\textbf{Note:} ultrasparse graphs form a subset of sparse graphs.

\textbf{Examples:} empty and complete graphs, chains, stars, trees, PA, ER, sparse but not ultrasparse\ldots

